---
import { Code as CodeBlock } from "astro:components";

interface Props {
  code: string;
  class?: string;
}

const { code, class: className = "" } = Astro.props;
---

<div class={`bibtex-block overflow-hidden rounded-2xl border border-white/10 ${className}`}>
  <div class="flex items-center border-b border-white/10 bg-white/[0.02] px-4 py-2.5">
    <img
      src="/assets/projects/markie/bibtex-logo.webp"
      alt="BibTeX"
      class="h-4 w-auto brightness-0 invert opacity-70"
    />
  </div>
  <CodeBlock code={code} lang="bibtex" theme="github-dark" />
</div>

<style>
  .bibtex-block :global(pre.astro-code) {
    background-color: color-mix(in srgb, white 3%, transparent) !important;
    margin: 0;
    padding: 1rem;
    font-size: 0.75rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
    counter-reset: line;
  }

  .bibtex-block :global(pre.astro-code .line) {
    display: inline-block;
    width: 100%;
    padding-left: 2.25em;
    position: relative;
  }

  .bibtex-block :global(pre.astro-code .line)::before {
    counter-increment: line;
    content: counter(line);
    position: absolute;
    left: 0;
    width: 1.75em;
    text-align: right;
    color: rgba(255, 255, 255, 0.3);
    user-select: none;
  }
</style>
