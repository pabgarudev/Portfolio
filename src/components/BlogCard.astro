---
import ArrowRight from "./icons/ArrowRight.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { slug, title, description, date, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const tagsText = tags.join(" · ");
---

<a
  href={`/blog/${slug}`}
  class="group relative flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.03] backdrop-blur-sm px-4 py-3.5 transition duration-300 hover:-translate-y-0.5 hover:border-[#7877c6]/30 hover:bg-white/[0.05] hover:shadow-lg hover:shadow-black/30 sm:gap-4 sm:px-5"
>
  <div
    class="pointer-events-none absolute -right-10 -top-10 h-32 w-32 rounded-full bg-[#7877c6] opacity-0 blur-[60px] transition duration-300 group-hover:opacity-20"
  >
  </div>

  <!-- Date sits in a bbox-style tag cut into the top border, echoing the
       detection-box framing on the hero photo. -->
  <time
    datetime={date.toISOString()}
    class="absolute -top-[11px] left-3 whitespace-nowrap rounded-[3px] border border-[#7877c6]/25 bg-neutral-950 px-1.5 py-0.5 font-mono text-[11px] font-medium leading-none tracking-tight text-neutral-200 sm:left-4"
  >
    <span class="font-black text-[#7877c6]/50">/* </span><span
      style="color: color-mix(in srgb, white 20%, #7877c6 80%);">{formattedDate}</span><span
      class="font-black text-[#7877c6]/50"> */</span>
  </time>

  <h2 class="relative min-w-0 flex-1 text-base font-bold leading-snug text-white transition-colors group-hover:text-[#b3b0ea] sm:flex-none sm:shrink-0 sm:max-w-[40%] sm:truncate sm:text-lg sm:leading-normal">
    {title}
  </h2>

  <p class="relative hidden min-w-0 flex-1 truncate text-sm text-white/50 sm:block">
    {description}
  </p>

  <span class="relative shrink-0 text-white/30 transition-all duration-300 group-hover:translate-x-1 group-hover:text-[#7877c6]">
    <ArrowRight class="size-4 sm:size-5" />
  </span>

  {
    tags.length > 0 && (
      <span class="absolute -bottom-[10px] right-3 max-w-[75%] truncate rounded-[3px] border border-white/15 bg-neutral-950 px-1.5 py-0.5 font-mono text-[10px] font-medium leading-none tracking-tight text-white/40 sm:right-4 sm:max-w-none">
        {tagsText}
      </span>
    )
  }
</a>
