---
const { pathname } = Astro.url;
const isHome = pathname === "/";
const isProjects = pathname.startsWith("/projects");
const isBlog = pathname.startsWith("/blog");
---

<nav
  id="mobile-menu"
  class="pointer-events-none fixed top-20 right-5 z-[1000] flex min-w-44 flex-col rounded-2xl
         border border-white/10 bg-neutral-950/30 backdrop-blur-xl shadow-xl
         p-5 gap-y-4
         opacity-0 scale-95 -translate-y-2 origin-top-right
         transition-all duration-100 ease-out"
>
  <a href="/" aria-current={isHome ? "page" : undefined}>Home</a>
  <a href="/#experience">Experience</a>
  <a href="/#education">Education</a>
  <a href="/projects" class="flex items-center gap-1.5" aria-current={isProjects ? "page" : undefined}>
    Projects
    <svg
      class="size-3.5"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M17 7l-10 10" />
      <path d="M8 7l9 0l0 9" />
    </svg>
  </a>
  <a href="/blog" class="flex items-center gap-1.5" aria-current={isBlog ? "page" : undefined}>
    Blog
    <svg
      class="size-3.5"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M17 7l-10 10" />
      <path d="M8 7l9 0l0 9" />
    </svg>
  </a>
  <a href="/#about-me">About me</a>
  <a href="/#contact">Contact</a>
  <a href="/cv.pdf" download="Pablo-Garcia-Ruiz-CV.pdf" class="flex items-center gap-1.5">
    CV
    <svg
      class="size-3.5"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2" />
      <path d="M7 11l5 5l5 -5" />
      <path d="M12 4l0 12" />
    </svg>
  </a>
</nav>

<script>
  const button = document.querySelector("#menu-button");
const menu = document.querySelector("#mobile-menu");
const middle = document.querySelector("#comment-middle");
const middleInner = document.querySelector("#comment-middle-inner");
const slashLeft = document.querySelector("#slash-left");

const GAP_DURATION = 200;
const ASTERISK_DURATION = 130;

let iconTimeout: ReturnType<typeof setTimeout> | undefined;

const setGap = (open: boolean) => {
  if (!middle) return;

  middle.classList.toggle("grid-cols-[1fr]", open);
  middle.classList.toggle("grid-cols-[0fr]", !open);

  middle.classList.toggle("overflow-visible", open);
  middle.classList.toggle("overflow-hidden", !open);

  middleInner?.classList.toggle("overflow-visible", open);
  middleInner?.classList.toggle("overflow-hidden", !open);

  slashLeft?.classList.toggle("translate-x-0.5", !open);
  slashLeft?.classList.toggle("translate-x-2", open);
};

const setAsterisks = (visible: boolean) => {
  middleInner?.classList.toggle("opacity-100", visible);
  middleInner?.classList.toggle("opacity-0", !visible);
};

const openMenu = () => {
  menu?.classList.remove("pointer-events-none", "opacity-0", "scale-95", "-translate-y-2");
  menu?.classList.add("opacity-100", "scale-100", "translate-y-0");
  button?.setAttribute("aria-expanded", "true");

  clearTimeout(iconTimeout);
  setAsterisks(false);
  setGap(true);
  iconTimeout = setTimeout(() => setAsterisks(true), GAP_DURATION);

  menu?.querySelector<HTMLAnchorElement>("a")?.focus();
};

const closeMenu = (returnFocus = false) => {
  menu?.classList.add("pointer-events-none", "opacity-0", "scale-95", "-translate-y-2");
  menu?.classList.remove("opacity-100", "scale-100", "translate-y-0");
  button?.setAttribute("aria-expanded", "false");

  clearTimeout(iconTimeout);
  setAsterisks(false);
  iconTimeout = setTimeout(() => setGap(false), ASTERISK_DURATION);

  if (returnFocus) (button as HTMLElement | null)?.focus();
};

const isMenuOpen = () => menu?.classList.contains("opacity-100") ?? false;

button?.addEventListener("click", () => {
  isMenuOpen() ? closeMenu() : openMenu();
});

document.addEventListener("keydown", (event) => {
  if (event.key === "Escape" && isMenuOpen()) closeMenu(true);
});

document.addEventListener("click", (event) => {
  if (!isMenuOpen()) return;
  const target = event.target as Node;
  if (menu?.contains(target) || button?.contains(target)) return;
  closeMenu();
});

menu?.querySelectorAll("a").forEach((link) => {
  link.addEventListener("click", () => closeMenu());
});
</script>