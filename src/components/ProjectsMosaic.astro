---
import ProjectCard from "./ProjectCard.astro";

const PROJECTS = [
  {
    title: "Markie",
    subtitle: "A Vision-Based Fiducial Object Input Device for Intuitive Interaction",
    year: 2025,
    category: "paper",
    firstAuthor: true,
    description:
      "A fiducial-object input device that turns everyday pose estimation into a natural way to interact with digital systems, built to be intuitive and accessible for users with diverse needs.",
    tags: ["Computer Vision", "HCI"],
    link: "https://www.uco.es/investiga/grupos/ava/portfolio/markie-your-fiducial-input-device/",
  },
  {
    title: "Sparse Camera Positioning",
    subtitle: "Sparse Indoor Camera Positioning",
    year: 2025,
    category: "paper",
    firstAuthor: true,
    description:
      "Indoor camera pose estimation without views overlapping. Derived from published research.",
    tags: ["Computer Vision"],
    link: "https://www.uco.es/investiga/grupos/ava/portfolio/sparse-indoor-camera-positioning/",
  },
  {
    title: "Indoor Camera Positioning",
    subtitle: "Large Scale Indoor Camera Positioning",
    year: 2024,
    category: "paper",
    firstAuthor: true,
    description:
      "Innovative adaptive indoor camera pose estimation system. Derived from published research.",
    tags: ["Computer Vision"],
    link: "https://www.uco.es/investiga/grupos/ava/portfolio/indoor-camera-positioning/",
  },
  {
    title: "Fiducial Objects",
    subtitle: "Multi-shape multi-marker creation",
    year: 2023,
    category: "paper",
    firstAuthor: true,
    description:
      "Generalised multi-shape multi-marker pose estimation system. Derived from published research.",
    tags: ["Computer Vision"],
    link: "https://www.uco.es/investiga/grupos/ava/portfolio/fiducial-object/",
  },
  {
    title: "Tiny Introduction to Fiducial Markers",
    year: 2023,
    category: "workshop",
    description:
      "Introduction to fiducial markers from scratch, covering detection algorithms, homography, pose estimation and 3D object management.",
    tags: ["Ready-to-use", "Open Source"],
    link: "https://github.com/pabgaruWorkshops/Tiny-Introduction-to-Fiducial-Markers",
  },
  {
    id: "thesis",
    title: "Advances in the Use of Fiducial Markers for Positioning Tasks with Cameras",
    subtitle: "Ph.D. Thesis · University of Córdoba",
    year: 2025,
    category: "thesis",
    description:
      "My doctoral dissertation compiling three years of research on fiducial marker design and indoor camera pose estimation, defended Cum Laude.",
    tags: ["Computer Vision", "Cum Laude"],
    link: "https://helvia.uco.es/xmlui/handle/10396/32915",
  },
  {
    title: "AVA Group Rebranding",
    subtitle: "Complete Visual Identity for Artificial Vision Applications",
    year: 2023,
    category: "design",
    description:
      "Full rebranding of the Artificial Vision Applications research group — new visual identity and website.",
    tags: ["Design"],
    link: "https://www.uco.es/investiga/grupos/ava/home/",
  },
];

// Bento spans keyed by title so they survive re-sorting.
const SPANS: Record<string, string> = {
  Markie: "sm:col-span-2 lg:col-span-2 lg:row-span-2",
  "Indoor Camera Positioning": "lg:row-span-2",
  "Tiny Introduction to Fiducial Markers": "sm:col-span-2 lg:col-span-1",
};

// Within the same year: thesis, then papers, then everything else.
const CATEGORY_PRIORITY: Record<string, number> = { thesis: 0, paper: 1, workshop: 2 };

const SORTED_PROJECTS = [...PROJECTS]
  .sort(
    (a, b) =>
      b.year - a.year ||
      (CATEGORY_PRIORITY[a.category] ?? 3) - (CATEGORY_PRIORITY[b.category] ?? 3)
  )
  .map((project) => ({
    ...project,
    // Every paper is open source.
    tags:
      project.category === "paper"
        ? Array.from(new Set([...project.tags, "Open Source"]))
        : project.tags,
  }));
// Filter pills shown above the grid. "all" is a synced master toggle;
// every other entry maps to one or more project categories and can be
// unchecked to hide those cards. Categories without an entry here are
// always shown.
const FILTERS = [
  { key: "all", label: "All", categories: [] as string[] },
  { key: "paper", label: "Papers", categories: ["paper"] },
  { key: "design", label: "Design", categories: ["design"] },
  { key: "others", label: "Others", categories: ["thesis", "workshop"] },
];
---

<div id="project-filters" class="mb-6 flex flex-wrap gap-2">
  {
    FILTERS.map((filter) => (
      <label class="inline-flex cursor-pointer items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-white/60 transition has-checked:border-white/30 has-checked:bg-white/15 has-checked:text-white">
        <input
          type="radio"
          name="project-filter"
          class="peer sr-only"
          data-filter={filter.key}
          data-categories={filter.categories.join(" ")}
          checked={filter.key === "all"}
        />
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-3 shrink-0 scale-0 opacity-0 transition-all duration-150 peer-checked:scale-100 peer-checked:opacity-100"
        >
          <path d="M5 12l5 5l10 -10"></path>
        </svg>
        {filter.label}
      </label>
    ))
  }
</div>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 lg:auto-rows-[minmax(220px,auto)] [grid-auto-flow:dense]">
  {
    SORTED_PROJECTS.map((project) => (
      <ProjectCard
        {...project}
        year={String(project.year)}
        span={SPANS[project.title] ?? ""}
      />
    ))
  }
</div>

<script>
  const filterContainer = document.getElementById("project-filters");
  const filterRadios = Array.from(filterContainer?.querySelectorAll<HTMLInputElement>("input[data-filter]") ?? []);
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-category]"));

  function applyFilters() {
    const active = filterRadios.find((r) => r.checked);
    const categories = active?.dataset.categories ? active.dataset.categories.split(" ") : [];
    // "all" carries no categories, meaning no restriction — show everything.
    const restrictTo = active && active.dataset.filter !== "all" ? new Set(categories) : null;

    for (const card of cards) {
      const visible = restrictTo === null || restrictTo.has(card.dataset.category ?? "");
      card.classList.toggle("hidden", !visible);
    }
  }

  for (const radio of filterRadios) radio.addEventListener("change", applyFilters);

  applyFilters();
</script>
