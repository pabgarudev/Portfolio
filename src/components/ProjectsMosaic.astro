---
import ProjectCard from "./ProjectCard.astro";
import { PROJECTS } from "../data/projects";

// Bento spans keyed by title so they survive re-sorting.
const SPANS: Record<string, string> = {
  Markie: "sm:col-span-2 lg:col-span-2 lg:row-span-2",
  "Indoor Camera Positioning": "lg:row-span-2",
  "Tiny Introduction to Fiducial Markers": "sm:col-span-2 lg:col-span-1",
};

// Within the same year: thesis, then papers, then everything else.
const CATEGORY_PRIORITY: Record<string, number> = { thesis: 0, paper: 1, workshop: 2 };

const SORTED_PROJECTS = [...PROJECTS]
  .sort(
    (a, b) =>
      // Pinned projects always float to the top, ahead of year/category ordering.
      (b.pinned ? 1 : 0) - (a.pinned ? 1 : 0) ||
      b.year - a.year ||
      (CATEGORY_PRIORITY[a.types[0]] ?? 3) - (CATEGORY_PRIORITY[b.types[0]] ?? 3)
  )
  .map((project) => ({
    ...project,
    // Every paper is open source.
    tags: project.types.includes("paper")
      ? Array.from(new Set([...project.tags, "Open Source"]))
      : project.tags,
  }));
// Filter pills shown above the grid. "all" is a synced master toggle;
// every other entry matches if any of a project's types is in its list,
// and can be unchecked to hide those cards. Types without an entry here
// are always shown.
const FILTERS = [
  { key: "all", label: "All", types: [] as string[] },
  { key: "paper", label: "Papers", types: ["paper"] },
  { key: "design", label: "Design", types: ["design"] },
  { key: "app", label: "App", types: ["app"] },
  { key: "others", label: "Others", types: ["thesis", "workshop"] },
];
---

<div id="project-filters" class="mb-6 flex flex-wrap gap-2 justify-center">
  {
    FILTERS.map((filter) => (
      <label class="inline-flex cursor-pointer items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-white/60 transition has-checked:border-white/30 has-checked:bg-white/15 has-checked:text-white">
        <input
          type="radio"
          name="project-filter"
          class="peer sr-only"
          data-filter={filter.key}
          data-types={filter.types.join(" ")}
          checked={filter.key === "all"}
        />
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-3 shrink-0 scale-0 opacity-0 transition-all duration-150 peer-checked:scale-100 peer-checked:opacity-100"
        >
          <path d="M5 12l5 5l10 -10"></path>
        </svg>
        {filter.label}
      </label>
    ))
  }
</div>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 lg:auto-rows-[minmax(220px,auto)] [grid-auto-flow:dense]">
  {
    SORTED_PROJECTS.map((project) => (
      <ProjectCard
        {...project}
        year={String(project.year)}
        span={SPANS[project.title] ?? ""}
      />
    ))
  }
</div>

<script>
  const filterContainer = document.getElementById("project-filters");
  const filterRadios = Array.from(filterContainer?.querySelectorAll<HTMLInputElement>("input[data-filter]") ?? []);
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-types]"));

  function applyFilters() {
    const active = filterRadios.find((r) => r.checked);
    const isAll = !active || active.dataset.filter === "all";
    const types = active?.dataset.types ? active.dataset.types.split(" ") : [];
    const restrictTypes = !isAll && types.length ? new Set(types) : null;

    for (const card of cards) {
      const cardTypes = (card.dataset.types ?? "").split(" ");
      const visible =
        isAll || (restrictTypes ? cardTypes.some((type) => restrictTypes.has(type)) : false);
      card.classList.toggle("hidden", !visible);
    }
  }

  for (const radio of filterRadios) radio.addEventListener("change", applyFilters);

  applyFilters();
</script>
