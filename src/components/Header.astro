<header class="relative flex justify-between items-center py-3 px-5 sm:px-8 w-full max-w-[1120px] mx-auto">
  <img
    src="/assets/p_shadow.png"
    alt="pabgaru icon"
    class="rounded-full w-auto h-12 shrink-0"
  />

  <nav class="hidden md:flex flex-row gap-x-10">
    <a href="#top">Home</a>
    <a href="#experience">Experience</a>
    <a href="#projects">Projects</a>
    <a href="#about-me">About me</a>
    <a href="#contact">Contact</a>
  </nav>

  <button
    id="menu-button"
    class="md:hidden text-white text-3xl leading-none"
    aria-label="Open menu"
  >
    ☰
  </button>

  <nav
    id="mobile-menu"
    class="hidden absolute top-full right-5 left-5 mt-3 rounded-2xl border border-white/10 bg-neutral-950/70 backdrop-blur-xl p-5 flex-col gap-y-4 z-50 shadow-xl"
  >
    <a href="#top">Home</a>
    <a href="#experience">Experience</a>
    <a href="#projects">Projects</a>
    <a href="#about-me">About me</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<script>
  const button = document.querySelector("#menu-button");
  const menu = document.querySelector("#mobile-menu");

  button?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    });
  });
</script>