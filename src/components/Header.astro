<header class="fixed top-0 left-1/2 -translate-x-1/2 z-[999] flex justify-between items-center py-3 px-5 sm:px-8 w-full max-w-[1120px] bg-neutral-950/20 backdrop-blur-md border-b border-white/5">
  <img
    src="/assets/p_shadow.png"
    alt="pabgaru icon"
    class="rounded-full w-auto h-12 shrink-0"
  />

  <nav class="hidden md:flex flex-row gap-x-10">
    <a href="#top">Home</a>
    <a href="#experience">Experience</a>
    <a href="#projects">Projects</a>
    <a href="#about-me">About me</a>
    <a href="#contact">Contact</a>
  </nav>

  <button
    id="menu-button"
    class="md:hidden text-white text-3xl leading-none"
    aria-label="Open menu"
  >
    ☰
  </button>

  <nav
  id="mobile-menu"
  class="hidden fixed top-20 left-5 right-5 rounded-2xl border border-white/10 bg-neutral-950/40 backdrop-blur-[40px] p-5 flex-col gap-y-4 z-[1000] shadow-xl"
>
    <a href="#top">Home</a>
    <a href="#experience">Experience</a>
    <a href="#projects">Projects</a>
    <a href="#about-me">About me</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<script>
  const button = document.querySelector("#menu-button");
  const menu = document.querySelector("#mobile-menu");

  button?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menu?.classList.toggle("flex");
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    });
  });
</script>