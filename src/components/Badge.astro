<span
    class="inline-flex items-center gap-2 bg-green-900 text-green-300 text-xs font-mono font-medium me-2 px-2.5 py-0.5 rounded"
>
    <span class="badge-dot relative flex size-2.5 shrink-0">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-300 opacity-75"></span>
        <span class="badge-dot-burst absolute inline-flex h-full w-full rounded-full bg-emerald-200"></span>
        <span class="badge-dot-core relative inline-flex size-2.5 rounded-full bg-emerald-300"></span>
    </span>
    <slot />
</span>

<style>
    .badge-dot {
        opacity: 0;
        transform: scale(0.3);
    }

    .badge-dot-burst {
        opacity: 0;
    }

    .badge-dot-core {
        box-shadow: 0 0 6px 1.5px rgba(52, 211, 153, 0.85);
    }

    :global(.badge-emphasize) .badge-dot {
        animation: badge-emphasis-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    :global(.badge-emphasize) .badge-dot-burst {
        animation: badge-emphasis-burst 0.7s ease-out;
    }

    @keyframes badge-emphasis-pop {
        0% { opacity: 0; transform: scale(0.3); }
        55% { opacity: 1; transform: scale(1.5); }
        100% { opacity: 1; transform: scale(1); }
    }

    @keyframes badge-emphasis-burst {
        0% { opacity: 0.8; transform: scale(1); }
        100% { opacity: 0; transform: scale(2.8); }
    }

    @media (prefers-reduced-motion: reduce) {
        .badge-dot {
            opacity: 1;
            transform: none;
        }
    }
</style>