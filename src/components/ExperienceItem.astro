---
import "../styles/global.css";
import ArrowRight from "./icons/ArrowRight.astro";
import Button from "./Button.astro";
const { date, role, org, description, link, isLast, logo, logoClass = "h-4.5" } = Astro.props;
---

<li class={`${isLast ? "" : "mb-10"} ms-4`}>
  <div class="absolute w-3 h-3 bg-white rounded-full mt-1.5 -start-1.5 border-2 border-neutral-950"></div>

  <time class="font-mono text-sm font-medium leading-none text-neutral-200 tracking-tight">
  <span class="text-[#7877c6]/50 mr-1 font-black">/* </span>
  <span style="color: color-mix(in srgb, white 20%, #7877c6 80%);">{date}</span>
  <span class="text-[#7877c6]/50 ml-1 font-black"> */</span>
</time>

  <div class="mt-3 flex flex-wrap items-center gap-2 text-sm font-semibold uppercase tracking-wider text-white/60">
    {org}
    {logo && <img src={logo} alt="" class={`${logoClass} w-auto shrink-0 opacity-80`} />}
  </div>

  <h3 class="text-2xl font-extrabold text-white mt-2 mb-1.5 tracking-wide">
    {role}
  </h3>

  <p class={`${link ? "mb-4" : ""} text-base font-normal text-pretty`} style="color: color-mix(in srgb, white 80%, #7877c6 20%);">
    {description}
  </p>

  {
    link && (
      <Button href={link}>
        Learn more
        <ArrowRight class="size-4" />
      </Button>
    )
  }
</li>