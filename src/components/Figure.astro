---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  width?: number;
  class?: string;
}

const { src, alt, caption, width = 1000, class: className = "mt-6 max-w-[680px]" } = Astro.props;
---

<figure class={`overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] ${className}`}>
  <Image src={src} width={width} format="webp" alt={alt} class="w-full" />
  {caption && (
    <figcaption class="border-t border-white/10 px-4 py-2.5 text-xs text-white/50">
      {caption}
    </figcaption>
  )}
</figure>
