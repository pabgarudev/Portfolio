---
import Calendar from "./icons/Calendar.astro";
import Article from "./icons/Article.astro";
import Code from "./icons/Code.astro";
import Camera from "./icons/Camera.astro";
import Award from "./icons/Award.astro";
import Pin from "./icons/Pin.astro";
import Grid from "./icons/Grid.astro";
import { CATEGORY_META, accentFor, APP_ACCENT, weightedAccents } from "../lib/categories";
import { accentPillStyle } from "../lib/pillStyles";

const {
  id,
  title,
  subtitle,
  year,
  description,
  tags = [],
  link,
  span = "",
  types = [],
  firstAuthor = false,
  pinned = false,
} = Astro.props;

// First type is the project's main type: same as the old single `category`
// field, it drives the pill/border/glow color. Any types after it only
// show up as a minority of colored squares in the scan-grid below.
const mainType = (types as string[])[0];
const meta = mainType ? CATEGORY_META[mainType as keyof typeof CATEGORY_META] : undefined;
const effectiveAccent = accentFor(mainType);
const CategoryIcon = meta?.icon;
const hasAppType = (types as string[]).includes("app");
const hasDesignType = mainType !== "design" && (types as string[]).includes("design");
const accentWeights = weightedAccents(types as string[]);

// The yellow thesis accent reads much brighter than the others at the same
// opacity, so it gets a dimmer glow.
const isThesis = mainType === "thesis";
const glowOpacity = isThesis
  ? "opacity-[0.1] group-hover:opacity-[0.18] group-active:opacity-[0.18]"
  : "opacity-[0.16] group-hover:opacity-30 group-active:opacity-30";

const NEUTRAL_PILL =
  "rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-[11px] font-mono font-medium text-white/60 whitespace-nowrap";
const ACCENT_PILL = "inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-[11px] font-mono font-medium whitespace-nowrap";
const ACCENT_PILL_STYLE =
  "border-color: color-mix(in srgb, var(--accent) 35%, transparent); background: color-mix(in srgb, var(--accent) 12%, transparent); color: color-mix(in srgb, var(--accent) 65%, white);";

const TAG_ICONS: Record<string, typeof Code> = {
  "Open Source": Code,
  "Computer Vision": Camera,
};

// Tags that call out a distinction earn the amber "award" treatment instead
// of the neutral pill.
const AWARD_TAGS = new Set(["Cum Laude", "Best Live Demonstration Award"]);

const normalizedTags = (tags as string[]).map((tag) => tag.toLowerCase());
const displayTags = tags as string[];

const isInternalLink = link?.startsWith("/");
const Wrapper = link ? "a" : "div";
const wrapperProps = link
  ? isInternalLink
    ? { href: link, "aria-label": `Open ${title}` }
    : { href: link, target: "_blank", rel: "noopener", "aria-label": `Open ${title}` }
  : {};
---

<Wrapper
  {...wrapperProps}
  id={id}
  data-types={(types as string[]).join(" ")}
  data-tags={normalizedTags.join(" ")}
  class={`project-card group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-6 sm:p-8 shadow-2xl transition duration-300 hover:bg-white/[0.05] active:bg-white/[0.05] scroll-mt-24 ${span}`}
  style={`--accent:${effectiveAccent}`}
>
  <div
    class={`pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full blur-[80px] transition-[width,height,opacity] duration-300 group-hover:h-96 group-hover:w-96 group-active:h-96 group-active:w-96 ${glowOpacity}`}
    style="background:var(--accent)"
  >
  </div>

  <div
    class="card-scan-grid pointer-events-none absolute inset-0"
    aria-hidden="true"
    data-accents={accentWeights.map((a) => a.color).join(",")}
    data-weights={accentWeights.map((a) => a.weight).join(",")}
  >
  </div>

  <div class="relative flex h-full flex-col">
    <div class="flex items-start justify-between gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span class={`inline-flex items-center gap-1 ${NEUTRAL_PILL}`}>
          <Calendar class="size-3" />
          {year}
        </span>
        {
          firstAuthor && (
            <span class={ACCENT_PILL} style={ACCENT_PILL_STYLE}>
              <Article class="size-3" />
              1st Author
            </span>
          )
        }
        {
          meta && CategoryIcon && (
            <span class={ACCENT_PILL} style={ACCENT_PILL_STYLE}>
              <CategoryIcon class="size-3" />
              {meta.label}
            </span>
          )
        }
        {
          hasAppType && (
            <span class={ACCENT_PILL} style={accentPillStyle(APP_ACCENT)}>
              <Grid class="size-3" />
              App
            </span>
          )
        }
        {
          hasDesignType && (
            <span class={ACCENT_PILL} style={accentPillStyle(CATEGORY_META.design.color)}>
              <CATEGORY_META.design.icon class="size-3" />
              {CATEGORY_META.design.label}
            </span>
          )
        }
      </div>
      {
        (pinned || link) && (
          <span class="flex items-center gap-2 shrink-0">
            {
              pinned && (
                <span
                  class="flex size-6 shrink-0 items-center justify-center rounded-full bg-white text-black"
                  title="Pinned"
                  aria-label="Pinned"
                >
                  <Pin class="size-4 rotate-[30deg]" />
                </span>
              )
            }
            {
              link && (
                <span class="text-white/30 transition group-hover:text-white/70 group-active:text-white/70">
                  <svg
                    class="size-5"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 13v6a2 2 0 0 1 -2 2h-11a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2h6" />
                    <path d="M11 13l9 -9" />
                    <path d="M15 4h5v5" />
                  </svg>
                </span>
              )
            }
          </span>
        )
      }
    </div>

    <h3 class="mt-3 text-xl sm:text-2xl font-bold text-white leading-snug">
      {title}
    </h3>
    {subtitle && <p class="mt-1 text-sm text-white/50">{subtitle}</p>}

    <p class="mt-4 text-sm text-white/60 leading-relaxed">
      {description}
    </p>

    {
      displayTags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-2 pt-6">
          {displayTags.map((tag: string) => {
            const TagIcon = TAG_ICONS[tag];
            return AWARD_TAGS.has(tag) ? (
              <span class="inline-flex items-center gap-1 rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-mono font-medium text-amber-300">
                <Award class="size-3" />
                {tag}
              </span>
            ) : (
              <span class="inline-flex items-center gap-1 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-white/60">
                {TagIcon && <TagIcon class="size-3" />}
                {tag}
              </span>
            );
          })}
        </div>
      )
    }
  </div>
</Wrapper>

<style>
  .project-card:hover,
  .project-card:active {
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .card-scan-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(32px, 1fr));
    align-content: start;
    z-index: 0;
  }

  .card-scan-cell {
    aspect-ratio: 1 / 1;
    background: var(--accent, #fff);
    opacity: 0;
    transition: opacity 0.6s ease-in-out, background-color 0.6s ease-in-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-scan-cell {
      display: none;
    }
  }
</style>

<script>
  // Must match the minmax() floor in .card-scan-grid's grid-template-columns.
  const CELL_PX = 32;

  const grids = document.querySelectorAll<HTMLElement>(".card-scan-grid");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    grids.forEach((grid) => {
      // Astro's scoped styles rely on a data-astro-cid-* attribute; cells
      // created here at runtime need it copied over or the scoped
      // .card-scan-cell rules (aspect-ratio, default opacity, etc.) won't match.
      const scopeAttr = grid.getAttributeNames().find((name) => name.startsWith("data-astro-cid"));

      const accents = (grid.dataset.accents ?? "").split(",").filter(Boolean);
      const weights = (grid.dataset.weights ?? "").split(",").map(Number);

      // Weighted pick: main type comes first and gets the largest slice,
      // so it dominates while later types show up as a minority of cells.
      const pickAccent = () => {
        if (accents.length <= 1) return accents[0];
        let r = Math.random();
        for (let i = 0; i < accents.length; i++) {
          if (r < weights[i]) return accents[i];
          r -= weights[i];
        }
        return accents[accents.length - 1];
      };

      const twinkle = (cell: HTMLElement) => {
        const tick = () => {
          cell.style.opacity = (0.015 + Math.random() * 0.05).toFixed(2);
          cell.style.backgroundColor = pickAccent();
          window.setTimeout(tick, 400 + Math.random() * 900);
        };
        window.setTimeout(tick, Math.random() * 600);
      };

      // Cell count is derived from the card's actual size rather than a
      // fixed number, since bento spans (e.g. Markie's 2x2) make some cards
      // far bigger than others, and that size changes across breakpoints.
      const fill = () => {
        const { width, height } = grid.getBoundingClientRect();
        const needed = Math.ceil(width / CELL_PX) * Math.ceil(height / CELL_PX);
        for (let i = grid.childElementCount; i < needed; i++) {
          const cell = document.createElement("span");
          cell.className = "card-scan-cell";
          if (scopeAttr) cell.setAttribute(scopeAttr, "");
          grid.appendChild(cell);
          twinkle(cell);
        }
      };

      fill();
      new ResizeObserver(fill).observe(grid);
    });
  }
</script>
