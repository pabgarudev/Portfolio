---
import Calendar from "./icons/Calendar.astro";
import Article from "./icons/Article.astro";
import Code from "./icons/Code.astro";
import Camera from "./icons/Camera.astro";
import Award from "./icons/Award.astro";
import { CATEGORY_META, accentFor } from "../lib/categories";

const {
  id,
  title,
  subtitle,
  year,
  description,
  tags = [],
  link,
  span = "",
  category,
  firstAuthor = false,
} = Astro.props;

const meta = category ? CATEGORY_META[category as keyof typeof CATEGORY_META] : undefined;
const effectiveAccent = accentFor(category);
const CategoryIcon = meta?.icon;

// The yellow thesis accent reads much brighter than the others at the same
// opacity, so it gets a dimmer glow.
const isThesis = category === "thesis";
const softOpacity = isThesis
  ? "opacity-[0.06] group-hover:opacity-[0.12] group-active:opacity-[0.12]"
  : "opacity-10 group-hover:opacity-20 group-active:opacity-20";
const fineOpacity = isThesis
  ? "opacity-[0.12] group-hover:opacity-[0.22] group-active:opacity-[0.22]"
  : "opacity-20 group-hover:opacity-35 group-active:opacity-35";

const NEUTRAL_PILL =
  "rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-[11px] font-mono font-medium text-white/60 whitespace-nowrap";

const TAG_ICONS: Record<string, typeof Code> = {
  "Open Source": Code,
  "Computer Vision": Camera,
};

const isInternalLink = link?.startsWith("/");
const Wrapper = link ? "a" : "div";
const wrapperProps = link
  ? isInternalLink
    ? { href: link, "aria-label": `Open ${title}` }
    : { href: link, target: "_blank", rel: "noopener", "aria-label": `Open ${title}` }
  : {};
---

<Wrapper
  {...wrapperProps}
  id={id}
  data-category={category}
  class={`project-card group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-6 sm:p-8 shadow-2xl transition duration-300 hover:bg-white/[0.05] active:bg-white/[0.05] scroll-mt-24 ${span}`}
  style={`--accent:${effectiveAccent}`}
>
  <div
    class={`grain-mask-soft pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full blur-[90px] transition-[width,height,opacity] duration-300 group-hover:h-[26rem] group-hover:w-[26rem] group-active:h-[26rem] group-active:w-[26rem] ${softOpacity}`}
    style="background:color-mix(in srgb, var(--accent) 60%, white)"
  >
  </div>
  <div
    class={`grain-mask pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full blur-[70px] transition-[width,height,opacity] duration-300 group-hover:h-80 group-hover:w-80 group-active:h-80 group-active:w-80 ${fineOpacity}`}
    style="background:var(--accent)"
  >
  </div>

  <div class="relative flex h-full flex-col">
    <div class="flex items-start justify-between gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span class={`inline-flex items-center gap-1 ${NEUTRAL_PILL}`}>
          <Calendar class="size-3" />
          {year}
        </span>
        {
          firstAuthor && (
            <span class={`inline-flex items-center gap-1 ${NEUTRAL_PILL}`}>
              <Article class="size-3" />
              1st Author
            </span>
          )
        }
        {
          meta && CategoryIcon && (
            <span
              class="inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-[11px] font-mono font-medium whitespace-nowrap"
              style="border-color: color-mix(in srgb, var(--accent) 35%, transparent); background: color-mix(in srgb, var(--accent) 12%, transparent); color: color-mix(in srgb, var(--accent) 65%, white);"
            >
              <CategoryIcon class="size-3" />
              {meta.label}
            </span>
          )
        }
      </div>
      {
        link && (
          <span class="text-white/30 transition group-hover:text-white/70 group-active:text-white/70">
            <svg
              class="size-5"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 13v6a2 2 0 0 1 -2 2h-11a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2h6" />
              <path d="M11 13l9 -9" />
              <path d="M15 4h5v5" />
            </svg>
          </span>
        )
      }
    </div>

    <h3 class="mt-3 text-xl sm:text-2xl font-bold text-white leading-snug">
      {title}
    </h3>
    {subtitle && <p class="mt-1 text-sm text-white/50">{subtitle}</p>}

    <p class="mt-4 text-sm text-white/60 leading-relaxed">
      {description}
    </p>

    {
      tags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-2 pt-6">
          {tags.map((tag: string) => {
            const TagIcon = TAG_ICONS[tag];
            return tag === "Cum Laude" ? (
              <span class="inline-flex items-center gap-1 rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-mono font-medium text-amber-300">
                <Award class="size-3" />
                {tag}
              </span>
            ) : (
              <span class="inline-flex items-center gap-1 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-white/60">
                {TagIcon && <TagIcon class="size-3" />}
                {tag}
              </span>
            );
          })}
        </div>
      )
    }
  </div>
</Wrapper>

<style>
  .project-card:hover,
  .project-card:active {
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }
</style>
