---
import Article from "./icons/Article.astro";

const {
  title,
  subtitle,
  year,
  description,
  tags = [],
  link,
  accent = "#7877c6",
  span = "",
  paper = false,
} = Astro.props;

const PAPER_ACCENT = "#2dd4bf";
const effectiveAccent = paper ? PAPER_ACCENT : accent;
---

<div
  class={`project-card group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-6 sm:p-8 shadow-2xl transition duration-300 hover:bg-white/[0.05] ${span}`}
  style={`--accent:${effectiveAccent}`}
>
  <div
    class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full opacity-20 blur-3xl transition duration-300 group-hover:opacity-35"
    style="background:var(--accent)"
  >
  </div>

  <div class="relative flex h-full flex-col">
    <div class="flex items-start justify-between gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span
          class="rounded-full border px-2.5 py-0.5 text-[11px] font-medium whitespace-nowrap"
          style="border-color: color-mix(in srgb, var(--accent) 35%, transparent); background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent);"
        >
          {year}
        </span>
        {
          paper && (
            <span
              class="inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-[11px] font-medium whitespace-nowrap"
              style="border-color: color-mix(in srgb, var(--accent) 35%, transparent); background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent);"
            >
              <Article class="size-3" />
              Paper
            </span>
          )
        }
      </div>
      {
        link && (
          <a
            href={link}
            target="_blank"
            rel="noopener"
            aria-label={`Open ${title}`}
            class="text-white/30 transition group-hover:text-white/70"
          >
            <svg
              class="size-4"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 13v6a2 2 0 0 1 -2 2h-11a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2h6" />
              <path d="M11 13l9 -9" />
              <path d="M15 4h5v5" />
            </svg>
          </a>
        )
      }
    </div>

    <h3 class="mt-3 text-xl sm:text-2xl font-bold text-white leading-snug">
      {title}
    </h3>
    {subtitle && <p class="mt-1 text-sm text-white/50">{subtitle}</p>}

    <p class="mt-4 flex-1 text-sm text-white/60 leading-relaxed">
      {description}
    </p>

    {
      tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/60">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }
</style>
