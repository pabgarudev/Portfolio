---
import ExperienceItem from "./ExperienceItem.astro";
import { LOGOS } from "../data/logos";

const EXPERIENCE = [
  {
    date: "Dec 2025 - Present",
    role: "Senior Vision Engineer",
    org: "Indra Group",
    description:
      "Designing and developing advanced computer vision solutions for defense and aerospace applications. Integrating industrial cameras and building automated vision-inspection systems in mission-critical environments.",
    logo: LOGOS.indra,
    link: "/blog/senior-vision-engineer-indra",
  },
  {
    date: "May 2025 - Dec 2025",
    role: "Software Consultant",
    org: "ALTEN Spain & Airbus",
    description:
      "Worked on-site in Madrid as a software consultant on defense projects for Airbus Defence & Space. Developed and maintained Python-based software solutions while collaborating within multidisciplinary engineering teams.",
    logo: LOGOS.airbus,
    logoClass: "h-3.5",
    link: "/blog/software-consultant-alten-airbus",
  },
  {
    date: "2021 - 2025",
    role: "Research Engineer",
    org: "University of Córdoba",
    description:
      "Conducted research in computer vision and artificial intelligence, focusing on image processing, fiducial markers, and machine learning. Developed research software and published scientific contributions.",
    logo: LOGOS.uco,
    link: "/blog/research-engineer-uco",
  }
];
---

<ol class="relative border-s border-default ms-3">
  {
    EXPERIENCE.map((item, index) => (
      <ExperienceItem
        {...item}
        isLast={index === EXPERIENCE.length - 1}
      />
    ))
  }
</ol>