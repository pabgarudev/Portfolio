---
import GraduationCap from "./icons/GraduationCap.astro";
const { title, institution, date, honor } = Astro.props;
---

<div class="group rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-6 shadow-xl transition hover:bg-white/[0.05] hover:border-[#7877c6]/30">
  <div class="flex items-start justify-between gap-3">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#7877c6]/20 bg-[#7877c6]/10 text-[#7877c6] transition group-hover:scale-110">
      <GraduationCap class="size-5" />
    </div>

    {
      honor && (
        <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-2.5 py-0.5 text-[11px] font-medium text-amber-300 whitespace-nowrap">
          {honor}
        </span>
      )
    }
  </div>

  <h3 class="mt-4 text-base font-semibold text-white leading-snug">
    {title}
  </h3>
  <p class="mt-1 text-sm text-white/60">{institution}</p>

  <p class="mt-4 text-xs font-medium tracking-wide text-white/40">
    {date}
  </p>
</div>
