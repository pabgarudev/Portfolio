<div class="rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-8 sm:p-10 shadow-2xl">

  <h2 class="text-2xl sm:text-xl font-bold text-white">
    Want to talk?
  </h2>

  <p class="mt-4 max-w-[560px] text-white/60 leading-relaxed">
    Send me a quick message and I’ll get back to you as soon as possible.
  </p>

  <form id="contact-form" class="mt-8 flex flex-col gap-4">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="flex flex-col gap-1.5">
        <label for="contact-name" class="text-xs font-medium text-white/50">
          Name
        </label>
        <input
          id="contact-name"
          type="text"
          name="name"
          required
          placeholder="Your name"
          class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none transition-colors focus:border-[#7877c6]/50"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="text-xs font-medium text-white/50">
          Email
        </label>
        <input
          id="contact-email"
          type="email"
          name="email"
          required
          placeholder="you@email.com"
          class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none transition-colors focus:border-[#7877c6]/50"
        />
      </div>
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="contact-message" class="text-xs font-medium text-white/50">
        Message
      </label>
      <textarea
        id="contact-message"
        name="message"
        rows="5"
        required
        placeholder="Tell me a bit about what you have in mind..."
        class="resize-none rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none transition-colors focus:border-[#7877c6]/50"
      ></textarea>
    </div>

    <div class="mt-2 flex flex-wrap items-center justify-between gap-4">
      <p class="text-xs text-white/40">
        Opens your email app with this pre-filled — or write to{" "}
        <a href="mailto:pabgarudev@gmail.com" class="text-white/60 underline underline-offset-2 hover:text-white">
          pabgarudev@gmail.com
        </a>{" "}
        directly.
      </p>

      <button
        type="submit"
        class="shrink-0 rounded-full bg-white px-6 py-3 font-medium text-neutral-950 transition-colors hover:bg-white/80"
      >
        Send message
      </button>
    </div>
  </form>
</div>

<script>
  const form = document.querySelector<HTMLFormElement>("#contact-form");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const name = (form.querySelector<HTMLInputElement>("#contact-name")?.value ?? "").trim();
    const email = (form.querySelector<HTMLInputElement>("#contact-email")?.value ?? "").trim();
    const message = (form.querySelector<HTMLTextAreaElement>("#contact-message")?.value ?? "").trim();

    const subject = `Portfolio contact from ${name}`;
    const body = `${message}\n\n— ${name} (${email})`;

    const mailto = `mailto:pabgarudev@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
  });
</script>