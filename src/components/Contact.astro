---
import LinkdInIcon from "./icons/LinkdIn.astro";
---

<div class="relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm shadow-2xl">
  <div class="grain-mask-soft pointer-events-none absolute -left-24 -top-24 h-72 w-72 opacity-10 blur-[90px]" style="background:#7877c6; border-radius:58% 42% 63% 37% / 41% 55% 45% 59%; transform:rotate(-8deg)"></div>
  <div class="grain-mask pointer-events-none absolute -left-16 -top-16 h-56 w-56 opacity-20 blur-[70px]" style="background:#7877c6; border-radius:34% 66% 71% 29% / 62% 38% 60% 40%; transform:rotate(12deg)"></div>
  <div class="grain-mask-soft pointer-events-none absolute -bottom-24 -right-24 h-72 w-72 opacity-10 blur-[90px]" style="background:#00e08f; border-radius:66% 34% 40% 60% / 55% 45% 60% 40%; transform:rotate(20deg)"></div>
  <div class="grain-mask pointer-events-none absolute -bottom-16 -right-16 h-56 w-56 opacity-20 blur-[70px]" style="background:#00e08f; border-radius:38% 62% 55% 45% / 36% 64% 42% 58%; transform:rotate(-15deg)"></div>

  <div class="relative grid gap-10 p-8 sm:p-10 lg:grid-cols-[1fr_260px]">
    <div>
      <h2 class="text-2xl sm:text-xl font-bold text-white">
        Let's build it
      </h2>

      <p class="mt-4 max-w-[560px] text-white/60 leading-relaxed">
        Send me a quick message and I’ll get back to you as soon as possible.
      </p>

      <form id="contact-form" class="mt-8 flex flex-col gap-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="flex flex-col gap-1.5">
            <label for="contact-name" class="text-xs font-medium text-white/50">
              Name
            </label>
            <input
              id="contact-name"
              type="text"
              name="name"
              required
              placeholder="Your name"
              class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none transition-colors focus:border-[#7877c6]/50"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="contact-email" class="text-xs font-medium text-white/50">
              Email
            </label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              placeholder="you@email.com"
              class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none transition-colors focus:border-[#7877c6]/50"
            />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="contact-message" class="text-xs font-medium text-white/50">
            Message
          </label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            required
            placeholder="Tell me a bit about what you have in mind..."
            class="resize-none rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none transition-colors focus:border-[#7877c6]/50"
          ></textarea>
        </div>

        <div class="mt-2 flex flex-wrap items-center justify-between gap-4">
          <p class="text-xs text-white/40">
            Opens your email app with this pre-filled, or write to{" "}
            <a href="mailto:pabgarudev@gmail.com" class="text-white/60 underline underline-offset-2 hover:text-white">
              pabgarudev@gmail.com
            </a>{" "}
            directly.
          </p>

          <button
            type="submit"
            class="inline-flex shrink-0 items-center gap-2 rounded-full bg-white px-6 py-3 font-medium text-neutral-950 transition-colors hover:bg-white/80"
          >
            Send message
            <svg
              class="size-4"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M10 14l11 -11" />
              <path d="M21 3l-6.5 18a0.55 .55 0 0 1 -1 0l-3.5 -7l-7 -3.5a0.55 .55 0 0 1 0 -1l18 -6.5" />
            </svg>
          </button>
        </div>
      </form>
    </div>

    <div class="flex flex-col gap-6 lg:border-l lg:border-white/10 lg:pl-10">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-white/40">
          Quick contact
        </p>

        <div class="mt-3 flex flex-col gap-2">
          <a
            href="mailto:pabgarudev@gmail.com"
            class="flex items-center gap-2.5 rounded-xl border border-white/10 bg-white/[0.02] px-4 py-2.5 text-sm text-white/70 transition hover:border-[#7877c6]/30 hover:bg-white/[0.05] hover:text-white"
          >
            <svg
              class="size-4 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z" />
              <path d="M3 7l9 6l9 -6" />
            </svg>
            <span class="truncate">pabgarudev@gmail.com</span>
          </a>

          <a
            href="https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-2.5 rounded-xl border border-white/10 bg-white/[0.02] px-4 py-2.5 text-sm text-white/70 transition hover:border-[#7877c6]/30 hover:bg-white/[0.05] hover:text-white"
          >
            <LinkdInIcon class="size-4 shrink-0" />
            LinkedIn
          </a>
        </div>
      </div>

      <div class="flex items-center gap-2 text-xs text-white/50">
        <span class="relative flex size-2 shrink-0">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex size-2 rounded-full bg-emerald-400"></span>
        </span>
        I usually respond within a day
      </div>
    </div>
  </div>
</div>

<script>
  const form = document.querySelector<HTMLFormElement>("#contact-form");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const name = (form.querySelector<HTMLInputElement>("#contact-name")?.value ?? "").trim();
    const email = (form.querySelector<HTMLInputElement>("#contact-email")?.value ?? "").trim();
    const message = (form.querySelector<HTMLTextAreaElement>("#contact-message")?.value ?? "").trim();

    const subject = `Let's talk, I'm ${name}!`;
    const body = `${message}\n\n- ${name} (${email})`;

    const mailto = `mailto:pabgarudev@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
  });
</script>