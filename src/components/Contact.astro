<div class="rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-8 sm:p-10 shadow-2xl">

  <h2 class="text-2xl sm:text-xl font-bold text-white">
    Want to talk?
  </h2>

  <p class="mt-4 max-w-[560px] text-white/60 leading-relaxed">
    Send me a quick message and I’ll get back to you as soon as possible.
  </p>

  <form
    class="mt-8 flex flex-col gap-4"
    action="mailto:pabgarudev@gmail.com"
    method="POST"
    enctype="text/plain"
  >
    <input
      type="text"
      name="name"
      placeholder="Your name"
      class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none focus:border-white/30 transition-colors"
    />

    <input
      type="email"
      name="email"
      placeholder="Your email"
      class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none focus:border-white/30 transition-colors"
    />

    <textarea
      name="message"
      rows="5"
      placeholder="Your message"
      class="resize-none rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3 text-white placeholder:text-white/35 outline-none focus:border-white/30 transition-colors"
    ></textarea>

    <button
      type="submit"
      class="mt-2 rounded-full bg-white px-6 py-3 font-medium text-neutral-950 hover:bg-white/80 transition-colors"
    >
      Send message
    </button>
  </form>
</div>