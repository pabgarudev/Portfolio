---
import GraduationCap from "./icons/GraduationCap.astro";
import LinkdIn from "./icons/LinkdIn.astro";
import SectionContainer from "./SectionContainer.astro";
import { COLLABORATORS, type CollaboratorId } from "../lib/collaborators";

interface Props {
  ids: CollaboratorId[];
  accent?: string;
}

const { ids, accent = "#5b55b5" } = Astro.props;
const people = ids.map((id) => COLLABORATORS[id]).filter(Boolean);

function initials(name: string) {
  return name
    .split(" ")
    .map((w) => w[0])
    .slice(0, 2)
    .join("");
}
---

{
  people.length > 0 && (
    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4">
        <GraduationCap class="size-5 text-white/40" />
        Collaborators
      </h2>
      <div class="flex flex-wrap gap-3">
        {people.map((person) => (
          <a
            href={person.linkedin}
            target="_blank"
            rel="noopener"
            class="group flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-3 pr-4 transition hover:border-white/30 hover:bg-white/[0.06]"
          >
            {"photo" in person && person.photo ? (
              <img
                src={person.photo}
                alt={person.name}
                class="size-11 shrink-0 rounded-full object-cover"
              />
            ) : (
              <span
                class="flex size-11 shrink-0 items-center justify-center rounded-full text-sm font-bold text-white"
                style={`background: color-mix(in srgb, ${accent} 55%, #1a1a2e);`}
              >
                {initials(person.name)}
              </span>
            )}
            <span class="flex flex-col">
              <span class="flex items-center gap-1.5 text-sm font-medium text-white">
                {person.name}
                <LinkdIn class="size-3.5 text-white/40 transition group-hover:text-white/70" />
              </span>
              <span class="text-xs text-white/50">
                {person.role} · {person.affiliation}
              </span>
            </span>
          </a>
        ))}
      </div>
    </SectionContainer>
  )
}
