---
import Users from "./icons/Users.astro";
import SectionContainer from "./SectionContainer.astro";
import { COLLABORATORS, type CollaboratorId } from "../lib/collaborators";

interface Props {
  ids: CollaboratorId[];
  accent?: string;
  title?: string;
}

const { ids, accent = "#5b55b5", title = "Collaborators" } = Astro.props;
const people = ids.map((id) => COLLABORATORS[id]).filter(Boolean);

function initials(name: string) {
  return name
    .split(" ")
    .map((w) => w[0])
    .slice(0, 2)
    .join("");
}
---

{
  people.length > 0 && (
    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4">
        <Users class="size-5 text-white/40" />
        {title}
      </h2>
      <div class="flex flex-wrap gap-3">
        {people.map((person) => (
          <a
            href={person.linkedin}
            target="_blank"
            rel="noopener"
            class="group relative flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] py-3 pl-3 pr-10 transition hover:border-white/30 hover:bg-white/[0.06]"
          >
            {person.photo ? (
              <img
                src={person.photo}
                alt={person.name}
                class="size-11 shrink-0 rounded-full object-cover"
              />
            ) : (
              <span
                class="flex size-11 shrink-0 items-center justify-center rounded-full text-sm font-bold text-white"
                style={`background: color-mix(in srgb, ${accent} 55%, #1a1a2e);`}
              >
                {initials(person.name)}
              </span>
            )}
            <span class="flex flex-col">
              <span class="text-sm font-medium text-white">
                {person.name}
              </span>
              <span class="text-xs text-white/50">
                {person.role} · {person.affiliation}
              </span>
            </span>
            <span class="absolute right-3 top-3 text-white/30 transition group-hover:text-white/70">
              <svg
                class="size-4.5"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M18 13v6a2 2 0 0 1 -2 2h-11a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2h6" />
                <path d="M11 13l9 -9" />
                <path d="M15 4h5v5" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </SectionContainer>
  )
}
