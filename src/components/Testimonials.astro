---
import Quote from "./icons/Quote.astro";
import User from "./icons/User.astro";
import { TESTIMONIALS, HAS_REAL_TESTIMONIALS } from "../lib/testimonials";

// Skeleton line widths, cycled per card so the placeholder cards don't all
// look identical.
const QUOTE_LINE_WIDTHS = [
  ["w-full", "w-full", "w-2/3"],
  ["w-full", "w-5/6", "w-1/2"],
  ["w-full", "w-full", "w-3/4"],
];
const NAME_WIDTHS = ["w-24", "w-28", "w-20"];
const ROLE_WIDTHS = ["w-32", "w-36", "w-28"];

// While there's only one real testimonial, two decorative skeleton cards
// peek out from behind it (left/right) to hint more are on their way.
// This stacked teaser goes away automatically once a second real
// testimonial is added, reverting to the normal scrollable track below.
const isSingleReal = HAS_REAL_TESTIMONIALS && TESTIMONIALS.length === 1;
// Narrower than the container on every breakpoint (not just desktop) so the
// peeking cards behind it stay visible on mobile too, instead of being
// fully covered by an edge-to-edge front card.
const SINGLE_CARD_WIDTH = "w-[86%]";
// Absolutely positioned (not grid items) so they never influence the
// track's own layout size, only overflow-hidden below needs to clip them.
const PEEK_CARD_CLASS = `pointer-events-none absolute inset-y-0 left-1/2 ${SINGLE_CARD_WIDTH} scale-[0.94] select-none rounded-2xl border border-white/10 bg-white/[0.03] p-5 opacity-70 blur-[1.5px]`;
---

<div class="relative overflow-x-hidden pb-3">
  <div
    id="testimonials-track"
    class={
      isSingleReal
        ? "relative w-full overflow-hidden py-6 lg:mx-auto lg:max-w-xl lg:overflow-visible"
        : `flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden ${HAS_REAL_TESTIMONIALS ? "" : "pointer-events-none select-none"}`
    }
    aria-hidden={HAS_REAL_TESTIMONIALS ? undefined : "true"}
  >
    {
      isSingleReal && (
        <div class={`${PEEK_CARD_CLASS} -translate-x-[60%] translate-y-2 sm:-translate-x-[66%] lg:-translate-x-[72%]`} aria-hidden="true">
          <Quote class="size-5 text-[#7877c6]/25" />
          <div class="mt-3 space-y-2 py-0.5">
            {QUOTE_LINE_WIDTHS[1].map((w) => (
              <div class={`h-3 rounded-full bg-white/10 ${w}`} />
            ))}
          </div>
          <div class="mt-4 flex items-center gap-3 border-t border-white/10 pt-3">
            <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-white/10 text-white/40">
              <User class="size-4.5" />
            </span>
            <div class="min-w-0 space-y-1.5">
              <div class={`h-3 rounded-full bg-white/15 ${NAME_WIDTHS[1]}`} />
              <div class={`h-2.5 rounded-full bg-white/10 ${ROLE_WIDTHS[1]}`} />
            </div>
          </div>
        </div>
      )
    }
    {
      TESTIMONIALS.map((t, i) => (
        <div class={`flex ${isSingleReal ? `relative z-10 ${SINGLE_CARD_WIDTH} mx-auto` : "w-full"} shrink-0 snap-start flex-col rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-5 transition hover:border-white/20 hover:bg-white/[0.05] ${isSingleReal ? "" : TESTIMONIALS.length > 1 ? "lg:w-[calc((100%-2rem)/3)]" : "lg:max-w-xl lg:mx-auto"}`}>
          <Quote class="size-5 text-[#7877c6]/40" />
          {HAS_REAL_TESTIMONIALS ? (
            <p class="testimonial-quote mt-3 flex-1 text-sm text-white/60 leading-relaxed" data-full={t.quote}>
              {t.quote}
            </p>
          ) : (
            <div class="mt-3 flex-1 space-y-2 py-0.5">
              {QUOTE_LINE_WIDTHS[i % QUOTE_LINE_WIDTHS.length].map((w) => (
                <div class={`h-3 rounded-full bg-white/10 ${w}`} />
              ))}
            </div>
          )}
          <div class="mt-4 flex items-center gap-3 border-t border-white/10 pt-3">
            {t.photo ? (
              <img src={t.photo} alt={t.name} class="size-9 shrink-0 rounded-full object-cover" />
            ) : (
              <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-white/10 text-white/40">
                <User class="size-4.5" />
              </span>
            )}
            {HAS_REAL_TESTIMONIALS ? (
              <div class="min-w-0">
                {"linkedin" in t && t.linkedin ? (
                  <a
                    href={t.linkedin}
                    target="_blank"
                    rel="noopener"
                    class="truncate text-sm font-semibold text-white underline decoration-white/20 hover:decoration-white/60"
                  >
                    {t.name}
                  </a>
                ) : (
                  <p class="truncate text-sm font-semibold text-white">{t.name}</p>
                )}
                <p class="truncate text-xs text-white/50">
                  {t.role}
                  {"affiliation" in t && t.affiliation ? ` · ${t.affiliation}` : ""}
                </p>
              </div>
            ) : (
              <div class="min-w-0 space-y-1.5">
                <div class={`h-3 rounded-full bg-white/15 ${NAME_WIDTHS[i % NAME_WIDTHS.length]}`} />
                <div class={`h-2.5 rounded-full bg-white/10 ${ROLE_WIDTHS[i % ROLE_WIDTHS.length]}`} />
              </div>
            )}
          </div>
        </div>
      ))
    }
    {
      isSingleReal && (
        <div class={`${PEEK_CARD_CLASS} -translate-x-[40%] translate-y-2 sm:-translate-x-[34%] lg:-translate-x-[28%]`} aria-hidden="true">
          <Quote class="size-5 text-[#7877c6]/25" />
          <div class="mt-3 space-y-2 py-0.5">
            {QUOTE_LINE_WIDTHS[2].map((w) => (
              <div class={`h-3 rounded-full bg-white/10 ${w}`} />
            ))}
          </div>
          <div class="mt-4 flex items-center gap-3 border-t border-white/10 pt-3">
            <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-white/10 text-white/40">
              <User class="size-4.5" />
            </span>
            <div class="min-w-0 space-y-1.5">
              <div class={`h-3 rounded-full bg-white/15 ${NAME_WIDTHS[2]}`} />
              <div class={`h-2.5 rounded-full bg-white/10 ${ROLE_WIDTHS[2]}`} />
            </div>
          </div>
        </div>
      )
    }
  </div>

  {
    !HAS_REAL_TESTIMONIALS && (
      <div class="pointer-events-none absolute inset-0 z-20 flex items-center justify-center px-4">
        <div class="rounded-2xl border border-white/15 bg-neutral-950/90 px-7 py-5 text-center shadow-xl shadow-black/40 backdrop-blur-sm">
          <p class="text-base font-semibold text-white">Be the first, come on!</p>
          <p class="mt-1.5 text-sm text-white/50">These cards are just placeholders until someone does.</p>
        </div>
      </div>
    )
  }

  {
    TESTIMONIALS.length > 1 && (
      <div class="absolute inset-x-0 bottom-0 flex translate-y-1/3 justify-center sm:inset-x-auto sm:right-3 sm:justify-end">
        <div class="inline-flex items-center gap-1 rounded-full border border-white/10 bg-neutral-950 p-1 shadow-lg shadow-black/40 backdrop-blur-sm">
          <button
            id="testimonials-prev"
            type="button"
            aria-label="Previous testimonials"
            disabled={!HAS_REAL_TESTIMONIALS}
            class="inline-flex size-8 items-center justify-center rounded-full font-mono text-sm text-white transition hover:scale-110 hover:bg-[#7877c6]/15 disabled:cursor-not-allowed disabled:opacity-30 disabled:hover:scale-100 disabled:hover:bg-transparent"
          >
            {"<"}
          </button>
          <button
            id="testimonials-next"
            type="button"
            aria-label="Next testimonials"
            disabled={!HAS_REAL_TESTIMONIALS}
            class="inline-flex size-8 items-center justify-center rounded-full font-mono text-sm tracking-widest text-white transition hover:scale-110 hover:bg-[#7877c6]/15 disabled:cursor-not-allowed disabled:opacity-30 disabled:hover:scale-100 disabled:hover:bg-transparent"
          >
            {"/>"}
          </button>
        </div>
      </div>
    )
  }
</div>

<script>
  const track = document.getElementById("testimonials-track");
  const prevBtn = document.getElementById("testimonials-prev") as HTMLButtonElement | null;
  const nextBtn = document.getElementById("testimonials-next") as HTMLButtonElement | null;

  if (track && prevBtn && nextBtn) {
    // Circular: paging past either end wraps around to the other side
    // instead of stopping, so the buttons stay active at all times.
    const scrollByPage = (dir: 1 | -1) => {
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (dir === 1 && track.scrollLeft >= maxScroll - 4) {
        track.scrollTo({ left: 0, behavior: "smooth" });
      } else if (dir === -1 && track.scrollLeft <= 4) {
        track.scrollTo({ left: maxScroll, behavior: "smooth" });
      } else {
        track.scrollBy({ left: dir * track.clientWidth, behavior: "smooth" });
      }
    };

    prevBtn.addEventListener("click", () => scrollByPage(-1));
    nextBtn.addEventListener("click", () => scrollByPage(1));
  }

  // Clamp quotes to 3 lines with a bold "[...]" sitting inline at the end
  // of the third line (not a separate line below), clickable to expand
  // to the full quote and back, on both desktop and mobile.
  const MORE_LABEL = "[...]";
  const LESS_LABEL = "[show less]";
  const quoteEls = document.querySelectorAll<HTMLParagraphElement>(".testimonial-quote");

  const makeToggle = (label: string, expanded: boolean) => {
    const b = document.createElement("b");
    b.textContent = label;
    b.className = "cursor-pointer font-bold text-white/80 transition hover:text-white";
    b.tabIndex = 0;
    b.setAttribute("role", "button");
    b.setAttribute("aria-expanded", String(expanded));
    return b;
  };

  // Renders a candidate cut using the exact same markup (text node + bold
  // <b>) that the final collapsed state uses, so the bold ellipsis's extra
  // width is accounted for during measurement, not just plain text.
  const renderCutForMeasurement = (p: HTMLParagraphElement, fullText: string, mid: number) => {
    p.textContent = "";
    p.appendChild(document.createTextNode(`${fullText.slice(0, mid).trimEnd()} `));
    const b = document.createElement("b");
    b.className = "font-bold";
    b.textContent = MORE_LABEL;
    p.appendChild(b);
  };

  // Binary-searches the longest prefix of `fullText` that, together with
  // the bold "[...]" appended, still fits within a 3-line box.
  const findCollapsedCut = (p: HTMLParagraphElement, fullText: string, maxHeight: number) => {
    let lo = 0;
    let hi = fullText.length;
    while (lo < hi) {
      const mid = Math.ceil((lo + hi) / 2);
      renderCutForMeasurement(p, fullText, mid);
      if (p.scrollHeight <= maxHeight) lo = mid;
      else hi = mid - 1;
    }
    return lo;
  };

  const renderCollapsed = (p: HTMLParagraphElement, fullText: string) => {
    p.textContent = fullText;
    const lineHeight = parseFloat(getComputedStyle(p).lineHeight) || p.clientHeight / 3;
    const maxHeight = lineHeight * 3 + 1;
    if (p.scrollHeight <= maxHeight) {
      p.textContent = fullText;
      p.dataset.truncated = "false";
      p.dataset.expanded = "false";
      p.classList.remove("cursor-pointer");
      return;
    }
    const cut = findCollapsedCut(p, fullText, maxHeight);
    p.textContent = `${fullText.slice(0, cut).trimEnd()} `;
    p.appendChild(makeToggle(MORE_LABEL, false));
    p.dataset.truncated = "true";
    p.dataset.expanded = "false";
    p.classList.add("cursor-pointer");
  };

  const renderExpanded = (p: HTMLParagraphElement, fullText: string) => {
    p.textContent = `${fullText} `;
    p.appendChild(makeToggle(LESS_LABEL, true));
    p.dataset.expanded = "true";
    p.classList.add("cursor-pointer");
  };

  // Tiny, subtle grow/shrink animation between collapsed and expanded
  // states: measure the height before and after the content swap, then
  // transition between the two instead of snapping instantly.
  const animateHeight = (p: HTMLParagraphElement, apply: () => void) => {
    const startHeight = p.getBoundingClientRect().height;
    apply();
    const endHeight = p.getBoundingClientRect().height;
    if (Math.abs(endHeight - startHeight) < 1) return;
    // `.testimonial-quote` is a `flex-1` item (flex-basis: 0%) inside the
    // card's column layout, so the flex algorithm recomputes its height on
    // every layout pass and silently ignores a plain `height` style, leaving
    // nothing to actually transition. Override the flex sizing for the
    // duration of the animation so the explicit height sticks.
    p.style.flex = "none";
    p.style.height = `${startHeight}px`;
    p.style.overflow = "hidden";
    p.style.transition = "height 200ms ease";
    void p.offsetHeight;
    // A single rAF can still land in the same frame as the style writes
    // above, so the browser never paints the "start" state and just jumps
    // straight to the end value. Nesting two rAFs guarantees a paint of
    // the start height happens before the end height is applied.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        p.style.height = `${endHeight}px`;
      });
    });
    const onEnd = (e: TransitionEvent) => {
      if (e.propertyName !== "height") return;
      p.style.transition = "";
      p.style.height = "";
      p.style.overflow = "";
      p.style.flex = "";
      p.removeEventListener("transitionend", onEnd);
    };
    p.addEventListener("transitionend", onEnd);
  };

  const toggle = (p: HTMLParagraphElement, fullText: string) => {
    animateHeight(p, () => {
      if (p.dataset.expanded === "true") renderCollapsed(p, fullText);
      else if (p.dataset.truncated === "true") renderExpanded(p, fullText);
    });
  };

  quoteEls.forEach((p) => {
    const fullText = (p.dataset.full ?? p.textContent ?? "").trim();
    p.dataset.full = fullText;
    renderCollapsed(p, fullText);
    // The whole quote is clickable, not just the "[...]"/"[show less]" flag.
    // The person's name lives outside this <p> (in a sibling element), so
    // its link is never intercepted by this handler.
    p.addEventListener("click", () => toggle(p, fullText));
    p.addEventListener("keydown", (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === "B" && (e.key === "Enter" || e.key === " ")) {
        e.preventDefault();
        toggle(p, fullText);
      }
    });
  });

  let resizeTimer: number | undefined;
  window.addEventListener("resize", () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      quoteEls.forEach((p) => {
        if (p.dataset.expanded === "true") return;
        renderCollapsed(p, p.dataset.full ?? "");
      });
    }, 150);
  });
</script>
