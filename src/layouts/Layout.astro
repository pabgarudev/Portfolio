---
import type { ImageMetadata } from "astro";
import Header from "../components/Header.astro";
import Analytics from "@vercel/analytics/astro";
import MobileMenu from "../components/MobileMenu.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import meImage from "../assets/me.png";
// Fonts
import '@fontsource-variable/onest'; // Supports weights 100-900
import '@fontsource-variable/jetbrains-mono'; // Secondary font, supports weights 100-800

interface Props {
	title: string;
	description: string;
	image?: string | ImageMetadata;
	structuredData?: object | object[];
}

const {
	title,
	description,
	image = meImage,
	structuredData,
} = Astro.props;

const extraSchemas = structuredData
	? (Array.isArray(structuredData) ? structuredData : [structuredData])
	: [];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(typeof image === "string" ? image : image.src, Astro.site);

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Pablo García Ruiz",
	url: Astro.site?.toString(),
	image: socialImageURL.toString(),
	jobTitle: "Computer Vision Engineer",
	description,
	sameAs: [
		"https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/",
		"https://github.com/pabgaru/",
	],
	knowsAbout: [
		"Computer Vision",
		"Object Detection",
		"Pose Estimation",
		"3D Reconstruction",
		"Artificial Intelligence",
	],
	address: {
		"@type": "PostalAddress",
		addressLocality: "Córdoba",
		addressCountry: "ES",
	},
};
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" type="application/rss+xml" title="Pablo García Ruiz - Blog" href={new URL("/rss.xml", Astro.site)} />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#0a0a0a" />
		<meta name="author" content="Pablo García Ruiz" />

		<!-- Open Graph / Facebook, LinkedIn -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content="Pablo García Ruiz - Portfolio" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageURL} />

		<!-- Structured data -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
		{extraSchemas.map((schema) => (
			<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
		))}
	</head>
	<body ontouchstart="">
		<a href="#main-content" class="skip-link">Skip to content</a>
		<div class="fixed inset-0 z-[-2] min-h-dvh w-full bg-neutral-950"></div>
		<div class="grain-mask-page pointer-events-none fixed inset-0 z-[-1] min-h-dvh w-full bg-[radial-gradient(ellipse_90%_60%_at_50%_0%,rgba(120,119,198,0.65),rgba(255,255,255,0))]"></div>
		<Header />
		<MobileMenu />
		<slot />
		<Footer />
		<Analytics />
	</body>
</html>

<style is:global>

	:root{
		color-scheme: dark;
	}

	html{
		font-family: 'Onest Variable', sans-serif;
		scroll-behavior: smooth;
	}

	body {
		background: #0a0a0a;
		display: flex;
		flex-direction: column;
		min-height: 100dvh;
		overflow-x: hidden;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}

	.skip-link {
		position: fixed;
		top: 1rem;
		left: 1rem;
		z-index: 1100;
		transform: translateY(-150%);
		background: white;
		color: black;
		padding: 0.625rem 1.25rem;
		border-radius: 9999px;
		font-size: 0.875rem;
		font-weight: 600;
		transition: transform 0.15s ease-out;
	}

	.skip-link:focus {
		transform: translateY(0);
	}
</style>
