---
import Layout from '../layouts/Layout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import ProjectsMosaic from '../components/ProjectsMosaic.astro';
import Code from '../components/icons/Code.astro';
---

<Layout
	title="Projects — Pablo García Ruiz"
	description="Selected computer vision research and side projects by Pablo García Ruiz: fiducial marker design, indoor camera positioning and pose estimation systems."
	image="/assets/me.png">
	<main class="px-5 sm:px-8">

		<SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-8">
			<a
				href="/#projects"
				class="inline-flex items-center gap-1.5 text-sm text-white/50 transition hover:text-white"
			>
				<svg
					class="size-4"
					xmlns="http://www.w3.org/2000/svg"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M5 12l14 0" />
					<path d="M5 12l6 6" />
					<path d="M5 12l6 -6" />
				</svg>
				Back home
			</a>

			<h1 class="text-white text-3xl md:text-4xl lg:text-5xl font-bold pt-4 pb-4 leading-tight flex items-center gap-3">
				<Code class="size-8 sm:size-10" />
				Projects
			</h1>
			<p class="text-base lg:text-lg text-white/60 max-w-[640px] leading-relaxed">
				A selection of computer vision research and side projects — from fiducial
				marker design to large-scale indoor camera positioning.
			</p>
		</SectionContainer>

		<section class="scroll-mt-24 w-full max-w-[1120px] mx-auto pb-24">
			<ProjectsMosaic />
		</section>
	</main>
</Layout>
