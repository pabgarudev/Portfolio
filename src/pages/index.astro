---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import Display from '../components/Display.astro';
import SocialPill from '../components/SocialPill.astro';
// Icons
import LinkedInIcon from '../components/icons/LinkedIn.astro';
import GitHubIcon from '../components/icons/GitHub.astro';
import MailIcon from '../components/icons/Mail.astro';
import ContactIcon from '../components/icons/ContactIcon.astro';
import AboutMeIcon from '../components/icons/AboutMeIcon.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Suitcase from '../components/icons/Suitcase.astro';
import GraduationCap from '../components/icons/GraduationCap.astro';
import Code from '../components/icons/Code.astro';
import Contact from '../components/Contact.astro';
import AboutMe from '../components/AboutMe.astro';

---

<Layout
	title="Pablo García Ruiz - Computer Vision Engineer & PhD"
	description="Pablo García Ruiz is a PhD in Computer Vision with 4+ years of experience in object detection, pose estimation and 3D reconstruction. Based in Córdoba, Spain, available for freelance and side gigs."
	image="/assets/me.png">
	<main class="px-5 sm:px-8">

		<SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-12">

			<img
				src="/assets/me.png"
				alt="Pablo García Ruiz, Computer Vision Engineer"
				width="128"
				height="128"
				fetchpriority="high"
				class="rounded-full size-32 mb-5"
			/>

			<a href="https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/">
			<h1 class="reveal-scene text-white text-3xl md:text-4xl lg:text-5xl font-bold pb-4 lg:pb-10 leading-tight">
				Hi, I’m <span class="reveal-word" data-word data-label="name 0.98">Pablo</span> <span class="reveal-word" data-word data-label="surname 0.97">García</span> <span class="reveal-word whitespace-nowrap" data-word data-label="surname 0.99">Ruiz</span>
				<span class="reveal-box" aria-hidden="true"></span>
				<span class="reveal-label" aria-hidden="true"></span>
			</h1>
			</a>
			<a class="flex justify-start items-start pb-8"
				href="https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/"
				target="_blank"
				rel="noopener"
				>
				<Badge>Available for Work</Badge>
				<span class="bg-purple-100 text-purple-800 text-xs font-mono font-medium me-2 px-2.5 py-0.5 rounded-sm dark:bg-purple-900 dark:text-purple-300">Freelance & Side Gigs</span>
			</a>
			<h2 class="text-base lg:text-xl opacity-85 text-wrap max-w-full sm:max-w-[600px] leading-relaxed">
				<b>Doctor in Computer Vision</b> <span style="color: #ff004f;">•</span> 4+ years experience <span style="color: #ff004f;">•</span> Expert in object detection, pose estimation & 3D reconstruction <span style="color: #ff004f;">•</span> <span><b>From Córdoba, Spain</b></span> <span style="color: #ff004f;">•</span> Passionate about research, innovation & real-world impact projects	 
			</h2>

			<!-- List of link badges -->
			<nav class="flex gap-4 mt-6 flex-wrap">
				<!-- Obtained in: https://svgl.app/?search=linkdin -->
				<!-- LinkedIn -->
				<SocialPill href="https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/">
					<LinkedInIcon class="size-5 lg:size-6" />
					LinkedIn
				</SocialPill>
				<!-- GitHub -->
				<SocialPill href="https://github.com/pabgaru/">
					<GitHubIcon class="size-5 lg:size-6" />
					Github
				</SocialPill>
				<!-- Mail -->
				<SocialPill href="mailto:pabgarudev@gmail.com">
					<MailIcon class="size-5 lg:size-6" />
					pabgarudev@gmail.com
				</SocialPill>
			</nav>
		</SectionContainer>

		<SectionContainer id="experience" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold mb- flex gap-x-3 items-center pb-5">
				<Suitcase class="size-7"></Suitcase>
				Work experience
			</h2>
			<Experience></Experience>
		</SectionContainer>

		<SectionContainer id="education" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold mb- flex gap-x-3 items-center pb-5">
				<GraduationCap class="size-7"></GraduationCap>
				Education
			</h2>
			<Education></Education>
		</SectionContainer>

		<SectionContainer id="projects" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold mb- flex gap-x-3 items-center pb-5">
				<Code class="size-7"></Code>
				Projects
			</h2>

			<a
				href="/projects"
				class="group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-sm p-8 sm:p-10 shadow-2xl transition hover:bg-white/[0.05] hover:border-[#7877c6]/30"
			>
				<div
					class="grain-mask-soft pointer-events-none absolute -right-24 -top-24 h-72 w-72 opacity-10 blur-[90px] transition duration-300 group-hover:opacity-20"
					style="background:#7877c6; border-radius:58% 42% 63% 37% / 41% 55% 45% 59%; transform:rotate(-8deg)"
				></div>
				<div
					class="grain-mask pointer-events-none absolute -right-16 -top-16 h-56 w-56 opacity-20 blur-[70px] transition duration-300 group-hover:opacity-35"
					style="background:#7877c6; border-radius:34% 66% 71% 29% / 62% 38% 60% 40%; transform:rotate(12deg)"
				></div>

				<div class="relative">
					<p class="max-w-[520px] text-sm sm:text-base text-white/60 leading-relaxed">
						From peer-reviewed papers and my Ph.D. thesis to fully open-sourced
						workshops, explore the research and hands-on work behind my Computer
						Vision career in a dedicated showcase.
					</p>

					<span class="mt-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-white transition group-hover:bg-white/10 group-hover:border-[#7877c6]/40">
						View all projects
						<svg
							class="size-4 transition group-hover:translate-x-0.5"
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M5 12l14 0" />
							<path d="M13 18l6 -6" />
							<path d="M13 6l6 6" />
						</svg>
					</span>
				</div>
			</a>
		</SectionContainer>

		<SectionContainer id="contact" class="py-12 pb-20">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<ContactIcon class="size-7"></ContactIcon>
				Contact
			</h2>
			<Contact />
		</SectionContainer>

		<SectionContainer id="about-me" class="py-12 pb-20">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<AboutMeIcon class="size-7 scale-x-[-1]"></AboutMeIcon>
				About me
			</h2>
			<AboutMe />
		</SectionContainer>
	</main>
</Layout>

<noscript>
	<style>
		.reveal-box, .reveal-label { display: none !important; }
		.reveal-word { clip-path: none !important; }
	</style>
</noscript>

<style>
	.reveal-scene {
		position: relative;
	}

	.reveal-word {
		display: inline-block;
		clip-path: inset(0 100% 0 0);
		transition: clip-path 0.35s ease-out;
	}

	.reveal-word.is-revealed {
		clip-path: inset(0 0 0 0);
	}

	.reveal-box {
		position: absolute;
		border: 2.5px solid #ff004f;
		border-radius: 2px;
		pointer-events: none;
		opacity: 0;
	}

	.reveal-label {
		position: absolute;
		transform: translateY(-100%);
		margin-top: 0;
		padding: 1px 4px;
		background: #ff004f;
		color: white;
		font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
		font-size: 10px;
		font-weight: 700;
		line-height: 1.5;
		border-radius: 2px 2px 2px 0;
		white-space: nowrap;
		pointer-events: none;
		letter-spacing: 0.02em;
		opacity: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal-box, .reveal-label {
			display: none;
		}

		.reveal-word {
			clip-path: none;
			transition: none;
		}
	}
</style>

<script>
	const PAD = 4;
	const MOVE_MS = 600;
	const LABEL_IN_MS = 220;
	const DWELL_MS = 500;

	const scene = document.querySelector<HTMLElement>(".reveal-scene");
	const box = document.querySelector<HTMLElement>(".reveal-box");
	const label = document.querySelector<HTMLElement>(".reveal-label");
	const words = Array.from(document.querySelectorAll<HTMLElement>("[data-word]"));
	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	function wait(ms: number) {
		return new Promise<void>((resolve) => setTimeout(resolve, ms));
	}

	function rectFor(word: HTMLElement, sceneEl: HTMLElement) {
		const sceneRect = sceneEl.getBoundingClientRect();
		const wordRect = word.getBoundingClientRect();
		return {
			left: wordRect.left - sceneRect.left - PAD,
			top: wordRect.top - sceneRect.top - PAD,
			width: wordRect.width + PAD * 2,
			height: wordRect.height + PAD * 2,
		};
	}

	function placeBox(boxEl: HTMLElement, labelEl: HTMLElement, rect: ReturnType<typeof rectFor>, withTransition: boolean) {
		const transition = withTransition
			? `left ${MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1), top ${MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1), width ${MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1), height ${MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1)`
			: "none";

		boxEl.style.transition = transition;
		boxEl.style.left = `${rect.left}px`;
		boxEl.style.top = `${rect.top}px`;
		boxEl.style.width = `${rect.width}px`;
		boxEl.style.height = `${rect.height}px`;

		labelEl.style.transition = transition;
		labelEl.style.left = `${rect.left}px`;
		labelEl.style.top = `${rect.top}px`;
	}

	async function run(sceneEl: HTMLElement, boxEl: HTMLElement, labelEl: HTMLElement) {
		placeBox(boxEl, labelEl, rectFor(words[0], sceneEl), false);
		void boxEl.offsetWidth;

		boxEl.style.transition = "opacity 0.2s ease-out";
		boxEl.style.opacity = "1";

		for (let i = 0; i < words.length; i++) {
			const word = words[i];

			if (i > 0) {
				placeBox(boxEl, labelEl, rectFor(word, sceneEl), true);
				await wait(MOVE_MS);
			}

			labelEl.textContent = word.dataset.label ?? "";
			labelEl.style.transition = "opacity 0.15s ease-out";
			labelEl.style.opacity = "1";
			await wait(LABEL_IN_MS);

			word.classList.add("is-revealed");
			await wait(DWELL_MS);

			labelEl.style.opacity = "0";
		}

		await wait(150);
		boxEl.style.transition = "opacity 0.3s ease-out";
		boxEl.style.opacity = "0";
	}

	if (scene && box && label && words.length > 0) {
		if (prefersReducedMotion) {
			words.forEach((w) => w.classList.add("is-revealed"));
		} else {
			run(scene, box, label);
		}
	}
</script>
