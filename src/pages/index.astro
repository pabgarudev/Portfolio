---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import Display from '../components/Display.astro';
import Button from '../components/Button.astro';
import meImage from '../assets/me.png';
// Icons
import LinkedInIcon from '../components/icons/LinkedIn.astro';
import GitHubIcon from '../components/icons/GitHub.astro';
import MailIcon from '../components/icons/Mail.astro';
import ContactIcon from '../components/icons/ContactIcon.astro';
import AboutMeIcon from '../components/icons/AboutMeIcon.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Suitcase from '../components/icons/Suitcase.astro';
import GraduationCap from '../components/icons/GraduationCap.astro';
import Code from '../components/icons/Code.astro';
import Book from '../components/icons/Book.astro';
import Quote from '../components/icons/Quote.astro';
import Contact from '../components/Contact.astro';
import AboutMe from '../components/AboutMe.astro';
import TeaserCard from '../components/TeaserCard.astro';
import Testimonials from '../components/Testimonials.astro';

---

<Layout
	title="Pablo García Ruiz - Computer Vision Engineer & PhD"
	description="Pablo García Ruiz is a PhD in Computer Vision with 4+ years of experience in object detection, pose estimation and 3D reconstruction. Based in Córdoba, Spain, available for freelance and side gigs."
	image={meImage}>
	<main id="main-content" class="px-5 sm:px-8">

		<SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-12">

			<div class="face-reveal-scene relative inline-block mb-5">
				<Image
					src={meImage}
					width={320}
					alt="Pablo García Ruiz, Computer Vision Engineer"
					fetchpriority="high"
					loading="eager"
					format="webp"
					class="rounded-full size-36 lg:size-40 block"
				/>
				<span class="reveal-box" id="face-box" aria-hidden="true">
					<span class="face-grid" aria-hidden="true">
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
						<span class="face-cell"></span>
					</span>
				</span>
				<span class="reveal-label" id="face-label" aria-hidden="true"></span>
			</div>

			<h1 class="reveal-scene text-white text-3xl md:text-4xl lg:text-5xl font-bold pb-4 lg:pb-10 leading-snug" aria-label="Hi, I’m Pablo García Ruiz">
				Hi, I’m <span class="reveal-word" data-word data-label="name 0.99">Pablo</span> <span class="reveal-word" data-word data-label="surname 0.97">García</span> <span class="reveal-word whitespace-nowrap" data-word data-label="surname 0.99">Ruiz</span>
				<span class="reveal-caret" aria-hidden="true"></span>
				<span class="reveal-label name-label" aria-hidden="true"></span>
				<span class="reveal-label name-label" aria-hidden="true"></span>
			</h1>
			<a
				class="flex flex-wrap justify-start items-start gap-2 pb-8"
				href="https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/"
				target="_blank"
				rel="noopener"
				>
				<span id="available-badge" class="badge-reveal">
					<Badge>Available for Work</Badge>
				</span>
				<!-- Zero-size, full-basis spacer: forces the pill after it onto its
				     own line below sm, without stretching the pill itself to fill
				     the row (which a plain w-full on the pill would do). -->
				<span class="basis-full sm:hidden" aria-hidden="true"></span>
				<span class="bg-purple-100 text-purple-800 text-xs font-mono font-medium px-2.5 py-0.5 rounded-sm dark:bg-purple-900 dark:text-purple-300">Freelance & Side Gigs</span>
			</a>
			<p class="text-base lg:text-xl opacity-85 text-wrap max-w-full sm:max-w-[600px] leading-relaxed">
				<b>Doctor in Computer Vision</b> <span style="color: #ff004f;">•</span> 4+ years experience <span style="color: #ff004f;">•</span> Expert in object detection, pose estimation & 3D reconstruction <span style="color: #ff004f;">•</span> <span><b>From Córdoba, Spain</b></span> <span style="color: #ff004f;">•</span> Passionate about research, innovation & real-world impact projects
			</p>

			<!-- List of link badges -->
			<nav class="flex gap-4 mt-6 flex-wrap">
				<!-- Obtained in: https://svgl.app/?search=linkdin -->
				<!-- LinkedIn -->
				<Button href="https://www.linkedin.com/in/pablo-garc%C3%ADa-ruiz-9640332a3/" icon={LinkedInIcon} external>
					LinkedIn
				</Button>
				<!-- GitHub -->
				<Button href="https://github.com/pabgaru/" icon={GitHubIcon} external>
					Github
				</Button>
				<!-- Mail -->
				<Button href="mailto:pabgarudev@gmail.com" icon={MailIcon} external>
					pabgarudev@gmail.com
				</Button>
			</nav>
		</SectionContainer>

		<SectionContainer id="experience" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<Suitcase class="size-7"></Suitcase>
				Work experience
			</h2>
			<Experience></Experience>
		</SectionContainer>

		<SectionContainer id="testimonials" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<Quote class="size-7"></Quote>
				What people say
			</h2>
			<Testimonials></Testimonials>
		</SectionContainer>

		<SectionContainer id="education" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<GraduationCap class="size-7"></GraduationCap>
				Education
			</h2>
			<Education></Education>
		</SectionContainer>

		<SectionContainer id="projects" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<Code class="size-7"></Code>
				Projects
			</h2>

			<TeaserCard
				href="/projects"
				description="From peer-reviewed papers and my Ph.D. thesis to fully open-sourced workshops: the research and hands-on work behind my Computer Vision career."
				buttonText="View all projects"
			/>
		</SectionContainer>

		<SectionContainer id="blog" class="py-12 pb-12">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<Book class="size-7"></Book>
				Blog
			</h2>

			<TeaserCard
				href="/blog"
				description="Notes on the roles I've held, the research behind them, and what Computer Vision engineering actually looks like day to day."
				buttonText="Read the blog"
			/>
		</SectionContainer>

		<SectionContainer id="about-me" class="py-12 pb-20">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<AboutMeIcon class="size-7 scale-x-[-1]"></AboutMeIcon>
				About me
			</h2>
			<AboutMe />
		</SectionContainer>

		<SectionContainer id="contact" class="py-12 pb-20">
			<h2 class="text-2xl font-semibold flex gap-x-3 items-center pb-5">
				<ContactIcon class="size-7"></ContactIcon>
				Contact
			</h2>
			<Contact />
		</SectionContainer>
	</main>
</Layout>

<noscript>
	<style>
		.reveal-box, .reveal-caret, .reveal-label { display: none !important; }
		.badge-reveal { opacity: 1 !important; max-width: none !important; }
	</style>
</noscript>

<style>
	.reveal-scene {
		position: relative;
	}

	.reveal-word {
		display: inline-block;
	}

	.reveal-word .char {
		transition: color 0.5s ease-out;
	}

	.reveal-word .char.char-hit {
		color: #ff004f;
		transition: color 0.08s ease-out;
	}

	.reveal-box {
		position: absolute;
		border: 2.5px solid #ff004f;
		border-radius: 0;
		pointer-events: none;
		opacity: 0;
	}

	.reveal-caret {
		position: absolute;
		width: 2px;
		background: #ff004f;
		pointer-events: none;
		opacity: 0;
	}

	.reveal-caret.blinking {
		animation: caret-blink 1.1s steps(1, jump-none) infinite;
	}

	@keyframes caret-blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.face-grid {
		position: absolute;
		inset: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-template-rows: repeat(3, 1fr);
		pointer-events: none;
	}

	.face-cell {
		background: #ff004f;
		opacity: 0;
		transition: opacity 0.4s ease-in-out;
	}

	.reveal-label {
		position: absolute;
		transform: translateY(-100%);
		margin-top: 0;
		padding: 1px 4px;
		background: #ff004f;
		color: white;
		font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
		font-size: 10px;
		font-weight: 700;
		line-height: 1.5;
		border-radius: 0;
		white-space: nowrap;
		pointer-events: none;
		letter-spacing: 0.02em;
		opacity: 0;
	}

	.reveal-label.name-label {
		transform: translate(-100%, -100%);
	}

	/* Surname label only: on narrow screens the name can wrap, so the label
	   flips to bottom-right of the caret instead of top-left to avoid
	   overlapping the wrapped line above it. Only the Y axis flips (anchored
	   at the caret's bottom, pulled back up by its own height) so the label
	   stays within the caret's height band and reads as "to the right"
	   rather than stacked underneath it. */
	.reveal-label.name-label.label-flip {
		transform: translateY(-100%);
	}

	.badge-reveal {
		display: inline-flex;
		max-width: 0;
		opacity: 0;
		overflow: hidden;
		white-space: nowrap;
		vertical-align: top;
		transition: max-width 0.45s ease-out, opacity 0.35s ease-out;
	}

	.badge-reveal.is-shown {
		max-width: var(--badge-w, 260px);
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.reveal-box, .reveal-caret, .reveal-label {
			display: none;
		}

		.badge-reveal {
			opacity: 1;
			max-width: none;
			transition: none;
		}
	}
</style>

<script>
	const CARET_PAD_V = 3;
	const LABEL_OFFSET_X = 3;
	const CARET_END_NUDGE_X = 4;
	const START_DELAY_MS = 400;
	const CARET_JUMP_MS = 100;
	const CHAR_STEP_MS = 45;
	const LABEL_IN_MS = 150;
	const DWELL_MS = 500;
	const FINAL_EXTRA_MS = 300;

	const scene = document.querySelector<HTMLElement>(".reveal-scene");
	const caret = scene?.querySelector<HTMLElement>(".reveal-caret") ?? null;
	// One label per word group (name, surname) so both can stay visible at once
	// instead of sharing/reusing a single element.
	const labelEls = scene ? Array.from(scene.querySelectorAll<HTMLElement>(".name-label")) : [];
	const words = Array.from(document.querySelectorAll<HTMLElement>("[data-word]"));
	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	const wordChars = words.map(splitIntoChars);

	function wait(ms: number) {
		return new Promise<void>((resolve) => setTimeout(resolve, ms));
	}

	function splitIntoChars(word: HTMLElement) {
		// Astro's scoped styles rely on a data-astro-cid-* attribute; spans created
		// here at runtime need it copied over or the scoped .char rules won't match.
		const scopeAttr = word.getAttributeNames().find((name) => name.startsWith("data-astro-cid"));

		const text = word.textContent ?? "";
		word.textContent = "";
		const chars: HTMLElement[] = [];
		for (const ch of text) {
			const charEl = document.createElement("span");
			charEl.className = "char";
			charEl.textContent = ch;
			charEl.setAttribute("aria-hidden", "true");
			if (scopeAttr) charEl.setAttribute(scopeAttr, "");
			word.appendChild(charEl);
			chars.push(charEl);
		}
		return chars;
	}

	function flashChar(charEl: HTMLElement) {
		charEl.classList.add("char-hit");
		window.setTimeout(() => charEl.classList.remove("char-hit"), 260);
	}

	function rectOf(el: HTMLElement, sceneEl: HTMLElement, atRightEdge = false) {
		const sceneRect = sceneEl.getBoundingClientRect();
		const elRect = el.getBoundingClientRect();
		return {
			left: (atRightEdge ? elRect.right : elRect.left) - sceneRect.left,
			top: elRect.top - sceneRect.top - CARET_PAD_V,
			height: elRect.height + CARET_PAD_V * 2,
		};
	}

	function placeCaret(caretEl: HTMLElement, labelEl: HTMLElement, rect: ReturnType<typeof rectOf>, durationMs: number, flip = false) {
		const transition = durationMs > 0
			? `left ${durationMs}ms linear, top ${durationMs}ms linear, height ${durationMs}ms linear`
			: "none";

		caretEl.style.transition = transition;
		caretEl.style.left = `${rect.left}px`;
		caretEl.style.top = `${rect.top}px`;
		caretEl.style.height = `${rect.height}px`;

		labelEl.classList.toggle("label-flip", flip);
		labelEl.style.transition = transition;
		labelEl.style.left = `${rect.left + LABEL_OFFSET_X}px`;
		labelEl.style.top = `${flip ? rect.top + rect.height : rect.top}px`;
	}

	// Pablo gets its own pass; García + Ruiz sweep as one continuous pass with a
	// single trailing label (they're both "surname", no need to call it out twice).
	const WORD_GROUPS: number[][] = [[0], [1, 2]];

	async function run(sceneEl: HTMLElement, caretEl: HTMLElement, labelEls: HTMLElement[]) {
		await wait(START_DELAY_MS);

		placeCaret(caretEl, labelEls[0], rectOf(wordChars[0][0], sceneEl), 0);
		void caretEl.offsetWidth;

		caretEl.style.transition = "opacity 0.2s ease-out";
		caretEl.style.opacity = "1";

		for (let g = 0; g < WORD_GROUPS.length; g++) {
			const groupIndices = WORD_GROUPS[g];
			const groupChars = groupIndices.flatMap((wordIndex) => wordChars[wordIndex]);
			const lastWord = words[groupIndices[groupIndices.length - 1]];
			const labelEl = labelEls[g];
			// Surname label only: flip to bottom-right on narrow screens, where the
			// name can wrap and a top-left label would overlap the line above.
			const flip = g === 1 && window.matchMedia("(max-width: 639.98px)").matches;

			if (g > 0) {
				// Caret already faded out at the end of the previous group: jump to this
				// group's start while invisible, then fade back in (no slide across the gap).
				placeCaret(caretEl, labelEl, rectOf(groupChars[0], sceneEl), 0, flip);
				void caretEl.offsetWidth;
				caretEl.style.transition = "opacity 0.15s ease-out";
				caretEl.style.opacity = "1";
				await wait(CARET_JUMP_MS);
			}
			flashChar(groupChars[0]);

			// Sweep across the remaining characters like an OCR reading pass.
			for (let j = 1; j < groupChars.length; j++) {
				placeCaret(caretEl, labelEl, rectOf(groupChars[j], sceneEl), CHAR_STEP_MS, flip);
				flashChar(groupChars[j]);
				await wait(CHAR_STEP_MS);
			}

			// Land just past the last character once the group has been "read".
			// On phone, the very last landing spot (after the "z" in Ruiz) gets a
			// small extra nudge right so the flipped label doesn't crowd it.
			const endRect = rectOf(groupChars[groupChars.length - 1], sceneEl, true);
			if (flip && g === WORD_GROUPS.length - 1) endRect.left += CARET_END_NUDGE_X;
			placeCaret(caretEl, labelEl, endRect, CHAR_STEP_MS, flip);
			await wait(CHAR_STEP_MS);

			caretEl.classList.add("blinking");

			labelEl.textContent = lastWord.dataset.label ?? "";
			labelEl.style.transition = "opacity 0.15s ease-out";
			labelEl.style.opacity = "1";
			await wait(LABEL_IN_MS);

			await wait(DWELL_MS);

			if (g < WORD_GROUPS.length - 1) {
				// Only the caret fades here so it can jump to the next group: this
				// group's label stays put and visible (see the "settled" cleanup below).
				caretEl.classList.remove("blinking");
				caretEl.style.transition = "opacity 0.15s ease-out";
				caretEl.style.opacity = "0";
				await wait(CARET_JUMP_MS);
			}
		}

		await wait(FINAL_EXTRA_MS);

		// The caret's job (marking the current reading position) is done, it fades out
		// normally here. The labels are handled separately: they stay up until "settled".
		caretEl.classList.remove("blinking");
		caretEl.style.transition = "opacity 0.3s ease-out";
		caretEl.style.opacity = "0";
	}

	function startNameStage() {
		if (scene && caret && labelEls.length === WORD_GROUPS.length && words.length > 0 && !prefersReducedMotion) {
			run(scene, caret, labelEls).then(() => {
				window.dispatchEvent(new Event("name-anim-done"));
			});
		} else {
			window.dispatchEvent(new Event("name-anim-done"));
		}
	}

	window.addEventListener("face-anim-done", startNameStage, { once: true });

	// Detection labels (name/surname) stay on screen through the whole intro; they only
	// fade once the "Available for Work" badge has fully finished showing.
	window.addEventListener("portfolio-intro-settled", () => {
		labelEls.forEach((labelEl) => {
			labelEl.style.transition = "opacity 0.3s ease-out";
			labelEl.style.opacity = "0";
		});
	}, { once: true });
</script>

<script>
	const FACE_MOVE_MS = 450;
	const FACE_LABEL_IN_MS = 200;
	const FACE_DWELL_MS = 600;
	const FACE_START_DELAY_MS = 600;
	const FACE_GRID_STOP_DELAY_MS = 300;
	const FACE_BOX_FADE_DELAY_MS = 500;
	const FACE_LABEL_TEXT = "face: 0.98";

	// Percentage-based guesses, as if a detector were scanning before locking on.
	// "size" is used for both width and height so the box always stays a perfect square.
	const FACE_STEPS = [
		{ left: 4, top: 4, size: 38 }, // off-face: top-left corner
		{ left: 58, top: 50, size: 38 }, // off-face: bottom-right corner
		{ left: 19, top: 8, size: 62 }, // final: locked onto the face
	];

	const faceScene = document.querySelector<HTMLElement>(".face-reveal-scene");
	const faceBox = document.querySelector<HTMLElement>("#face-box");
	const faceLabel = document.querySelector<HTMLElement>("#face-label");
	const facePrefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	function faceWait(ms: number) {
		return new Promise<void>((resolve) => setTimeout(resolve, ms));
	}

	const faceCells = Array.from(document.querySelectorAll<HTMLElement>(".face-cell"));
	let faceCellTimers: number[] = [];

	function startFaceGridFlicker() {
		faceCells.forEach((cell) => {
			const tick = () => {
				cell.style.opacity = (0.08 + Math.random() * 0.5).toFixed(2);
				faceCellTimers.push(window.setTimeout(tick, 300 + Math.random() * 500));
			};
			tick();
		});
	}

	function stopFaceGridFlicker() {
		faceCellTimers.forEach((id) => clearTimeout(id));
		faceCellTimers = [];
		faceCells.forEach((cell) => {
			cell.style.opacity = "0";
		});
	}

	function pxRect(sceneEl: HTMLElement, step: (typeof FACE_STEPS)[number]) {
		const w = sceneEl.clientWidth;
		const h = sceneEl.clientHeight;
		const base = Math.min(w, h);
		const size = (step.size / 100) * base;
		return {
			left: (step.left / 100) * w,
			top: (step.top / 100) * h,
			width: size,
			height: size,
		};
	}

	function placeFaceBox(rect: ReturnType<typeof pxRect>, withTransition: boolean) {
		if (!faceBox || !faceLabel) return;
		const transition = withTransition
			? `left ${FACE_MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1), top ${FACE_MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1), width ${FACE_MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1), height ${FACE_MOVE_MS}ms cubic-bezier(0.22, 1, 0.36, 1)`
			: "none";

		faceBox.style.transition = transition;
		faceBox.style.left = `${rect.left}px`;
		faceBox.style.top = `${rect.top}px`;
		faceBox.style.width = `${rect.width}px`;
		faceBox.style.height = `${rect.height}px`;

		faceLabel.style.transition = transition;
		faceLabel.style.left = `${rect.left}px`;
		faceLabel.style.top = `${rect.top}px`;
	}

	async function runFace(sceneEl: HTMLElement, boxEl: HTMLElement, labelEl: HTMLElement) {
		await faceWait(FACE_START_DELAY_MS);

		placeFaceBox(pxRect(sceneEl, FACE_STEPS[0]), false);
		void boxEl.offsetWidth;

		boxEl.style.transition = "opacity 0.2s ease-out";
		boxEl.style.opacity = "1";
		startFaceGridFlicker();
		await faceWait(FACE_DWELL_MS);

		for (let i = 1; i < FACE_STEPS.length; i++) {
			placeFaceBox(pxRect(sceneEl, FACE_STEPS[i]), true);
			await faceWait(FACE_MOVE_MS);
			await faceWait(FACE_DWELL_MS);
		}

		labelEl.textContent = FACE_LABEL_TEXT;
		labelEl.style.transition = "opacity 0.15s ease-out";
		labelEl.style.opacity = "1";
		await faceWait(FACE_LABEL_IN_MS);

		// Hand off to the name animation as soon as the face label lands, instead of
		// waiting for the rest of this sequence too.
		window.dispatchEvent(new Event("face-anim-done"));

		// Detection is "confirmed" once the label shows, so the scanning grid flicker
		// stops shortly after.
		await faceWait(FACE_GRID_STOP_DELAY_MS);
		stopFaceGridFlicker();

		// The bounding box's job is done once detection is confirmed, it fades out
		// normally here. Only the label sticks around (see "settled" listener below).
		await faceWait(FACE_BOX_FADE_DELAY_MS - FACE_GRID_STOP_DELAY_MS);
		boxEl.style.transition = "opacity 0.3s ease-out";
		boxEl.style.opacity = "0";
	}

	if (faceScene && faceBox && faceLabel && !facePrefersReducedMotion) {
		runFace(faceScene, faceBox, faceLabel);
	} else {
		window.dispatchEvent(new Event("face-anim-done"));
	}

	// The "face: 0.98" label stays on screen through the whole intro; it only fades
	// once the "Available for Work" badge has fully finished showing.
	window.addEventListener("portfolio-intro-settled", () => {
		if (!faceLabel) return;
		faceLabel.style.transition = "opacity 0.3s ease-out";
		faceLabel.style.opacity = "0";
	}, { once: true });
</script>

<script>
	const availableBadge = document.querySelector<HTMLElement>("#available-badge");
	const badgePrefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	// Matches .badge-reveal's max-width transition (the longer of its two transitions):
	// how long the pill takes to fully grow in.
	const BADGE_GROW_IN_MS = 450;
	// Extra breathing room after the badge is fully shown before the tags disappear,
	// so it doesn't feel like they vanish the instant it lands.
	const BADGE_SETTLE_EXTRA_MS = 1000;

	function showAvailableBadge() {
		if (!availableBadge) return;
		availableBadge.style.setProperty("--badge-w", `${availableBadge.scrollWidth}px`);
		availableBadge.classList.add("is-shown");
		if (!badgePrefersReducedMotion) {
			// Let the pill grow into view first, then pop the live dot in shortly after.
			window.setTimeout(() => {
				availableBadge.classList.add("badge-emphasize");
			}, 700);
		}

		// Once the badge has fully finished showing, tell the face/name/surname
		// detection labels they can fade out now.
		window.setTimeout(
			() => window.dispatchEvent(new Event("portfolio-intro-settled")),
			badgePrefersReducedMotion ? 0 : BADGE_GROW_IN_MS + BADGE_SETTLE_EXTRA_MS
		);
	}

	if (availableBadge) {
		if (badgePrefersReducedMotion) {
			showAvailableBadge();
		} else {
			window.addEventListener("name-anim-done", showAvailableBadge, { once: true });
		}
	}
</script>
