---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import BlogCard from "../../components/BlogCard.astro";
import Book from "../../components/icons/Book.astro";
import { itemListSchema, breadcrumbSchema } from "../../lib/structuredData";

const title = "Blog - Pablo García Ruiz";
const description = "Notes on computer vision engineering, research, and the roles behind them.";
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const posts = (await getCollection("blog", ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const structuredData = [
  itemListSchema({
    name: "Blog",
    description,
    url: pageUrl,
    items: posts.map((post) => ({
      name: post.data.title,
      url: new URL(`/blog/${post.id}`, Astro.site).toString(),
    })),
  }),
  breadcrumbSchema([
    { name: "Home", url: new URL("/", Astro.site).toString() },
    { name: "Blog", url: pageUrl },
  ]),
];
---

<Layout title={title} description={description} structuredData={structuredData}>
  <main id="main-content" class="px-5 sm:px-8">
    <SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-8">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm text-white/50 transition hover:text-white"
      >
        <svg
          class="size-4"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12l14 0" />
          <path d="M5 12l6 6" />
          <path d="M5 12l6 -6" />
        </svg>
        Back home
      </a>

      <h1 class="text-white text-3xl md:text-4xl lg:text-5xl font-bold pt-4 pb-4 leading-tight flex items-center gap-3">
        <Book class="size-8 sm:size-10" />
        Blog
      </h1>
      <p class="text-base lg:text-lg text-white/60 max-w-[640px] leading-relaxed">
        {description}
      </p>
    </SectionContainer>

    <section class="scroll-mt-24 w-full max-w-[800px] mx-auto pb-24">
      {
        posts.length > 0 ? (
          <div class="flex flex-col gap-4">
            {posts.map((post) => (
              <BlogCard
                slug={post.id}
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
              />
            ))}
          </div>
        ) : (
          <p class="text-white/50 text-center">No posts yet, check back soon.</p>
        )
      }
    </section>
  </main>
</Layout>
