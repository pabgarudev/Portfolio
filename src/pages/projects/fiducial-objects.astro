---
import Layout from "../../layouts/Layout.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import Calendar from "../../components/icons/Calendar.astro";
import Article from "../../components/icons/Article.astro";
import GitHub from "../../components/icons/GitHub.astro";
import Braces from "../../components/icons/Braces.astro";
import Book from "../../components/icons/Book.astro";
import Shield from "../../components/icons/Shield.astro";
import Download from "../../components/icons/Download.astro";
import Camera from "../../components/icons/Camera.astro";
import Collaborators from "../../components/Collaborators.astro";
import { Code as CodeBlock } from "astro:components";
import { CATEGORY_META, accentFor } from "../../lib/categories";

const title = "Fiducial Objects";
const subtitle = "Custom Design and Evaluation";
const year = 2023;
const category = "paper";
const firstAuthor = true;
const tags = ["Computer Vision", "Open Source"];
const heroImage = "/assets/projects/fiducial-objects/hero.jpg";

const categoryMeta = CATEGORY_META[category];
const CategoryIcon = categoryMeta.icon;
const accent = accentFor(category);

const techStack = [
  { name: "C++", icon: "/assets/tech/cpp.png", bg: "#e0f0fc", text: "#062f4a" },
  { name: "OpenCV", icon: "/assets/tech/opencv.png", bg: "#ffffff", text: "#000000" },
  { name: "CMake", icon: "/assets/tech/cmake.png", bg: "#ffffff", text: "#000000" },
];

const PILL =
  "inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-white/60 whitespace-nowrap";
const ACCENT_PILL = "inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-mono font-medium whitespace-nowrap";
const accentPillStyle = `border-color: color-mix(in srgb, ${accent} 35%, transparent); background: color-mix(in srgb, ${accent} 12%, transparent); color: color-mix(in srgb, ${accent} 65%, white);`;

const bibtex = `@article{garcia-ruiz2023fiducial,
  author  = {Garc\\'{\\i}a-Ruiz, Pablo and Romero-Ramirez, Francisco J. and Mu\\~{n}oz-Salinas, Rafael and Mar\\'{\\i}n-Jim\\'{e}nez, Manuel J. and Medina-Carnicer, Rafael},
  title   = {Fiducial Objects: Custom Design and Evaluation},
  journal = {Sensors},
  volume  = {23},
  year    = {2023},
  number  = {24},
  articleno = {9649},
  doi     = {10.3390/s23249649},
  url     = {https://www.mdpi.com/1424-8220/23/24/9649}
}`;
---

<Layout title={`${title} - Pablo García Ruiz`} description={subtitle} image={heroImage}>
  <main class="px-5 sm:px-8">
    <SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-16">
      <a
        href="/projects"
        class="inline-flex items-center gap-1.5 text-sm text-white/50 transition hover:text-white"
      >
        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12l14 0" />
          <path d="M5 12l6 6" />
          <path d="M5 12l6 -6" />
        </svg>
        Back to projects
      </a>

      <div class="mt-6 flex flex-wrap items-center gap-2">
        <span class={PILL}><Calendar class="size-3" />{year}</span>
        {firstAuthor && (
          <span class={ACCENT_PILL} style={accentPillStyle}>
            <Article class="size-3" />
            1st Author
          </span>
        )}
        <span class={ACCENT_PILL} style={accentPillStyle}>
          <CategoryIcon class="size-3" />
          {categoryMeta.label}
        </span>
      </div>

      <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {title}
      </h1>
      <p class="mt-3 text-base lg:text-lg text-white/60 leading-relaxed">{subtitle}</p>

      <div class="mt-5 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-white/60">
            {tag}
          </span>
        ))}
      </div>

      <div class="relative mt-10 flex justify-center py-6">
        <div
          class="pointer-events-none absolute inset-0 m-auto h-56 w-56 rounded-full blur-[90px] opacity-20"
          style={`background:${accent}`}
        >
        </div>
        <img src={heroImage} alt={title} class="relative w-full max-w-2xl lg:max-w-lg rounded-2xl" />
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Abstract</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          Camera pose estimation is vital in fields like robotics, medical imaging, and
          augmented reality, and <em>fiducial markers</em> — square patterns such as
          ArUco and AprilTag — are widely preferred for their efficiency. However, as
          single flat markers, their accuracy and usable viewing angle are inherently
          limited. Attaching several markers to a 3D object (a{" "}
          <strong class="text-white/85">fiducial object</strong>) improves visibility
          from multiple viewpoints, but existing approaches mainly wrap standard square
          markers around non-square object faces, wasting usable surface area.
        </p>
        <p>
          This work introduces a method for creating fiducial objects with{" "}
          <strong class="text-white/85">custom-shaped markers</strong> that optimize
          coverage of each face of the 3D solid, improving both space utilization and
          marker detectability at greater distances. Alongside the design method, we
          present a technique for precisely estimating a fiducial object's configuration
          from multiviewpoint images, and release the code, tutorials, and application
          needed to build and calibrate these objects.
        </p>
        <p>
          An empirical analysis across noise levels, blur, and scale variations shows
          that these customized markers significantly outperform traditional square
          markers for pose estimation, marking a meaningful step forward for
          fiducial-marker-based positioning.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Camera class="size-5 text-white/40" />How It Works</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          Starting from a target 3D solid — a cube, dodecahedron, or any of several other
          geometries — each face is treated as a separate canvas: instead of forcing a
          square ArUco pattern onto it and wasting the unused corners, a custom marker
          shape is generated that fills the face edge to edge, maximizing the amount of
          detectable pattern visible from a distance or at a steep angle.
        </p>
        <p>
          Those custom markers are rendered as textures and applied to the physical,
          3D-printed object. Because no two fiducial objects are manufactured with
          perfect geometric precision, a calibration step follows: a set of
          multiviewpoint snapshots of the printed object is used to estimate its exact
          vertex configuration, correcting for small deviations from the ideal digital
          model. The pose-estimation pipeline then combines detections from every visible
          face of that calibrated configuration into a single, more accurate and more
          robust 6DoF pose at run time.
        </p>
      </div>
      <div class="mt-6 max-w-[680px] overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]">
        <img
          src="/assets/projects/fiducial-objects/paper/how-it-works.jpg"
          alt="Pipeline diagram: marker design on each face of a target solid, rendering onto a 3D fiducial object, capturing multiviewpoint object snapshots, and estimating the object's vertex configuration."
          class="w-full"
        />
        <p class="border-t border-white/10 px-4 py-2.5 text-xs text-white/40">
          Fiducial object creation pipeline, from García-Ruiz et al., "Fiducial Objects: Custom Design and Evaluation," Sensors 2023.
        </p>
      </div>

      <div class="mt-6 max-w-[680px] overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]">
        <img
          src="/assets/projects/fiducial-objects/paper/marker-schemes.jpg"
          alt="Custom marker schemes optimized for seven different solid shapes: tetrahedron, cube, octahedron, hexagonal prism, dodecahedron, rhombic dodecahedron, and icosahedron."
          class="w-full"
        />
        <p class="border-t border-white/10 px-4 py-2.5 text-xs text-white/40">
          Custom-shaped marker schemes designed for seven solid geometries.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Download class="size-5 text-white/40" />Download</h2>
      <p class="text-white/80 leading-relaxed max-w-[560px]">
        The code, tutorials, and application to build and calibrate fiducial objects are
        openly available.
      </p>
      <a
        href="https://github.com/pabgaru/Fiducial-Objects"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-mono text-white/80 transition hover:border-white/30 hover:bg-white/15 hover:text-white"
      >
        <GitHub class="size-4" />
        View on GitHub
      </a>
      <div class="mt-5 flex flex-wrap items-center gap-3">
        {techStack.map((tech) => (
          <span
            class="inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-mono font-medium"
            style={`background: ${tech.bg}; color: ${tech.text}; border-color: color-mix(in srgb, ${tech.text} 20%, transparent);`}
          >
            <img src={tech.icon} alt="" class="size-4 rounded-sm object-contain" />
            {tech.name}
          </span>
        ))}
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Camera class="size-5 text-white/40" />Evaluation</h2>
      <p class="text-white/80 leading-relaxed max-w-[560px]">
        Custom-shaped markers were benchmarked against traditional square markers across
        varying noise levels, blur, and scale, using the experimental camera-positioning
        setup below.
      </p>
      <div class="mt-6 max-w-[680px] overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]">
        <img
          src="/assets/projects/fiducial-objects/paper/experiment-setup.jpg"
          alt="Experimental camera-positioning configuration used to evaluate fiducial object pose estimation accuracy."
          class="w-full"
        />
        <p class="border-t border-white/10 px-4 py-2.5 text-xs text-white/40">
          Experimental camera-positioning setup used to benchmark custom-shaped markers against traditional square markers.
        </p>
      </div>
    </SectionContainer>

    <Collaborators ids={["francisco-jose-romero-ramirez"]} accent={accent} />

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Braces class="size-5 text-white/40" />Citing</h2>
      <p class="text-white/80 mb-4">If you use this work in your research, please cite:</p>
      <div class="bibtex-block overflow-hidden rounded-2xl border border-white/10">
        <div class="flex items-center border-b border-white/10 bg-white/[0.02] px-4 py-2.5">
          <img
            src="/assets/projects/markie/bibtex-logo.webp"
            alt="BibTeX"
            class="h-4 w-auto brightness-0 invert opacity-70"
          />
        </div>
        <CodeBlock code={bibtex} lang="bibtex" theme="github-dark" />
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Article class="size-5 text-white/40" />Paper</h2>
      <p class="text-white/80 leading-relaxed max-w-[560px]">
        The full paper is openly available (open access) in Sensors, hosted on PubMed Central.
      </p>
      <a
        href="https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10747356/"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-mono text-white/80 transition hover:border-white/30 hover:bg-white/15 hover:text-white"
      >
        <Article class="size-4" />
        View on PubMed Central
      </a>
    </SectionContainer>

    <SectionContainer class="pb-24">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Shield class="size-5 text-white/40" />License</h2>
      <p class="text-white/80 text-sm">
        This software is licensed under{" "}
        <a
          href="https://github.com/pabgaru/Fiducial-Objects/blob/main/LICENSE"
          target="_blank"
          rel="noopener"
          class="font-mono text-white/90 underline decoration-white/20 hover:text-white"
        >
          MIT License
        </a>
        .
      </p>
    </SectionContainer>

  </main>
</Layout>

<style>
  .bibtex-block :global(pre.astro-code) {
    background-color: color-mix(in srgb, white 3%, transparent) !important;
    margin: 0;
    padding: 1rem;
    font-size: 0.75rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
    counter-reset: line;
  }

  .bibtex-block :global(pre.astro-code .line) {
    display: inline-block;
    width: 100%;
    padding-left: 2.25em;
    position: relative;
  }

  .bibtex-block :global(pre.astro-code .line)::before {
    counter-increment: line;
    content: counter(line);
    position: absolute;
    left: 0;
    width: 1.75em;
    text-align: right;
    color: rgba(255, 255, 255, 0.3);
    user-select: none;
  }
</style>
