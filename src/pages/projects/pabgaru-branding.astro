---
import Layout from "../../layouts/Layout.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import BackToProjects from "../../components/BackToProjects.astro";
import ProjectMetaPills from "../../components/ProjectMetaPills.astro";
import ProjectTags from "../../components/ProjectTags.astro";
import { Image } from "astro:assets";
import Palette from "../../components/icons/Palette.astro";
import Book from "../../components/icons/Book.astro";
import Code from "../../components/icons/Code.astro";
import FaceDetectionLoop from "../../components/FaceDetectionLoop.astro";
import { accentFor } from "../../lib/categories";
import { creativeWorkSchema, breadcrumbSchema } from "../../lib/structuredData";
import heroGif from "../../assets/projects/pabgaru-branding/hero.gif";
import logoImage from "../../assets/p_shadow.png";

const title = "My Brand";
const subtitle = "Personal Visual Identity";
const year = 2024;
const category = "design";
const tags = ["Design", "Branding"];

const accent = accentFor(category);

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const structuredData = [
  creativeWorkSchema({
    headline: title,
    description: subtitle,
    author: "Pablo García-Ruiz",
    datePublished: String(year),
    url: pageUrl,
    image: new URL(heroGif.src, Astro.site).toString(),
  }),
  breadcrumbSchema([
    { name: "Home", url: new URL("/", Astro.site).toString() },
    { name: "Projects", url: new URL("/projects", Astro.site).toString() },
    { name: title, url: pageUrl },
  ]),
];
---

<Layout title={`${title} - Pablo García Ruiz`} description={subtitle} structuredData={structuredData}>
  <main id="main-content" class="px-5 sm:px-8">
    <SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-16">
      <BackToProjects />

      <ProjectMetaPills year={year} category={category} />

      <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {title}
      </h1>
      <p class="mt-3 text-base lg:text-lg text-white/60 leading-relaxed">{subtitle}</p>

      <ProjectTags tags={tags} />

      <div class="relative mt-10 flex justify-center py-6">
        <div
          class="pointer-events-none absolute inset-0 m-auto h-56 w-56 rounded-full blur-[90px] opacity-20"
          style={`background:${accent}`}
        >
        </div>
        <div class="relative flex w-full max-w-xl items-center justify-center overflow-hidden rounded-2xl bg-white">
          <img
            src={heroGif.src}
            width={heroGif.width}
            height={heroGif.height}
            alt="Animated reveal of the pabgaru mark: a cursive lowercase p rendered in 3D, flanked by a pair of code angle brackets, in coral on a light studio background"
            class="w-full"
          />
        </div>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Overview</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          A personal mark to put on my own work: a cursive lowercase{" "}
          <strong class="text-white/85">p</strong> (for Pablo) flanked by a pair of
          code angle brackets, the creative and developer sides of the same signature.
          Rendered in 3D, in coral on a soft studio backdrop, it's meant to work as a
          still logo or as this short reveal animation.
        </p>
        <p>
          I built it as an excuse to actually learn a 3D/motion pipeline end to end:
          modeling the letterform, lighting and rendering a clean studio look, and
          animating a reveal, rather than just picking a font and a hex code. The
          bigger goal behind it is to get comfortable making these kinds of assets
          myself, so I can keep producing useful, reusable resources (logos, intros,
          icons) for my own projects instead of outsourcing every piece of visual
          identity.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Code class="size-5 text-white/40" />Where It Shows Up</h2>
      <p class="max-w-[680px] text-white/80 leading-relaxed mb-5">
        A few examples of resources this project has already produced, reused live
        elsewhere on this site rather than parked in a folder.
      </p>
      <div class="grid max-w-[680px] gap-4 sm:grid-cols-2">
        <div class="flex flex-col items-center gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-6 text-center">
          <div class="flex h-40 w-40 items-center justify-center rounded-full bg-white shadow-lg">
            <Image src={logoImage} width={192} format="webp" alt="The pabgaru mark, cropped into a circular badge" class="h-20 w-auto" />
          </div>
          <p class="text-sm text-white/60 leading-relaxed">
            The same mark, cropped into a circular badge, sits top-left of the header
            on every page of this site.
          </p>
        </div>
        <div class="flex flex-col items-center gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-6 text-center">
          <div class="flex h-40 w-40 items-center justify-center">
            <FaceDetectionLoop />
          </div>
          <p class="text-sm text-white/60 leading-relaxed">
            A reuse of the homepage intro's detection-style animation, a bounding box
            scanning and locking onto a photo, looping here instead of running once.
          </p>
        </div>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-24">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Palette class="size-5 text-white/40" />What's Next</h2>
      <p class="max-w-[680px] text-white/80 leading-relaxed">
        This mark is the first piece of a small personal system: color, typography,
        and a few more lockups are still taking shape as I keep learning the tools
        behind it. Consider this page a living record of that process.
      </p>
    </SectionContainer>
  </main>
</Layout>
