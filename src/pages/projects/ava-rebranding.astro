---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import BackToProjects from "../../components/BackToProjects.astro";
import ProjectMetaPills from "../../components/ProjectMetaPills.astro";
import ProjectTags from "../../components/ProjectTags.astro";
import Palette from "../../components/icons/Palette.astro";
import Book from "../../components/icons/Book.astro";
import { accentFor } from "../../lib/categories";
import { creativeWorkSchema, breadcrumbSchema } from "../../lib/structuredData";
import heroImage from "../../assets/projects/ava-rebranding/logo.png";
import constructionImage from "../../assets/projects/ava-rebranding/proposal/construction.png";
import secondaryIconImage from "../../assets/projects/ava-rebranding/proposal/secondary-icon.png";
import paletteImage from "../../assets/projects/ava-rebranding/proposal/palette.png";
import typographyImage from "../../assets/projects/ava-rebranding/proposal/typography.png";
import lockupsImage from "../../assets/projects/ava-rebranding/proposal/lockups.png";

const title = "AVA Group Rebranding";
const subtitle = "Complete Visual Identity for Artificial Vision Applications";
const year = 2023;
const category = "design";
const tags = ["Design", "Rebranding"];

const accent = accentFor(category);

const steps = [
  {
    title: "Introduction & Values",
    description: "I opened the deck with the question every rebrand has to answer before anything else: keep the AVA acronym or move away from it, and which values the mark should actually carry — technology, innovation, vision, and computation — plus whether this was the group's first real identity or a rebrand of an existing one.",
  },
  {
    title: "Basic Symbology",
    description: "The starting point was the group's own initials. I folded three ribbon shapes into the letters A-V-A, then formalized that shape into a repeatable construction block — a fixed 6-unit-wide, 17-unit-tall module folded at a 28° angle — so the mark redraws identically at any size, from a favicon to a banner.",
    image: constructionImage,
    caption: "Icon construction: the A-V-A ribbon block and its underlying grid.",
  },
  {
    title: "Secondary Icon",
    description: "For tighter spaces — social avatars, favicons — I designed a secondary mark: an eye-shaped arc wrapping a simplified version of the same ribbon block, a direct nod to \"Vision\" with its own clear-space rules.",
    image: secondaryIconImage,
    caption: "Secondary icon construction: the eye arc and its clear-space grid.",
  },
  {
    title: "Color System",
    description: "Two navy blues (#0e296b, #264796) and a light accent blue (#abc3ff) on white, chosen and contrast-checked for legibility — up to 13.56:1 — so the palette holds up in both light and reversed, knockout-on-navy applications.",
    image: paletteImage,
    caption: "The proposed palette with contrast ratios checked against white and against each other.",
  },
  {
    title: "Typography",
    description: "League Spartan carries the wordmark and headings; Roboto handles body copy — a geometric display face paired with a neutral workhorse, so the identity stays legible at both banner and paragraph scale.",
    image: typographyImage,
    caption: "League Spartan for headings and the wordmark, Roboto for body copy.",
  },
  {
    title: "Preferred Lockups",
    description: "Finally, I locked down how the icon and wordmark combine — icon above wordmark, icon beside wordmark — repeated across the full palette, including reversed versions for use on navy backgrounds.",
    image: lockupsImage,
    caption: "Preferred icon-and-wordmark lockups across the palette, light and reversed.",
  },
  {
    title: "How to Move Forward",
    description: "The deck closed with a rollout plan rather than a finished mandate: review the core resources, implement the identity using the preferred versions, roll it out everywhere it's needed, rebuild the site around it, generate templates for different areas of the group's work, and, eventually, grow it into a fuller brand universe.",
  },
];

const openQuestions = [
  "Keep the AVA acronym, or move toward a new name entirely?",
  "Is this the group's first real identity, or a rebrand of an existing one?",
  "Should the palette fold in values from specific research fields, or stay general?",
  "Any restrictions on when the secondary (eye) icon can be used on its own?",
  "Any licensing considerations for the chosen typefaces?",
];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const structuredData = [
  creativeWorkSchema({
    headline: title,
    description: subtitle,
    author: "Pablo García-Ruiz",
    datePublished: String(year),
    url: pageUrl,
    image: new URL(heroImage.src, Astro.site).toString(),
  }),
  breadcrumbSchema([
    { name: "Home", url: new URL("/", Astro.site).toString() },
    { name: "Projects", url: new URL("/projects", Astro.site).toString() },
    { name: title, url: pageUrl },
  ]),
];
---

<Layout title={`${title} - Pablo García Ruiz`} description={subtitle} image={heroImage} structuredData={structuredData}>
  <main id="main-content" class="px-5 sm:px-8">
    <SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-16">
      <BackToProjects />

      <ProjectMetaPills year={year} category={category} />

      <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {title}
      </h1>
      <p class="mt-3 text-base lg:text-lg text-white/60 leading-relaxed">{subtitle}</p>

      <ProjectTags tags={tags} />

      <div class="relative mt-10 flex justify-center py-6">
        <div
          class="pointer-events-none absolute inset-0 m-auto h-56 w-56 rounded-full blur-[90px] opacity-20"
          style={`background:${accent}`}
        >
        </div>
        <div class="relative flex w-full max-w-md items-center justify-center rounded-2xl bg-white p-10">
          <Image src={heroImage} width={640} format="webp" alt="AVA — Aplicaciones de la Visión Artificial logo" class="w-full max-w-xs" />
        </div>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Overview</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          A full rebranding of the <strong class="text-white/85">Artificial Vision
          Applications (AVA)</strong> research group at the University of Córdoba,
          covering a new visual identity and a redesigned website to present the
          group's research to the public.
        </p>
        <p>
          I presented it as a formal brand proposal deck to the group rather than a
          finished, drop-in identity. Below is that deck's actual chapter order — the
          steps I walked the group through, from what the mark needed to say down to
          how it's meant to be applied.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Palette class="size-5 text-white/40" />The Steps</h2>
      <div class="max-w-[680px] space-y-10">
        {steps.map((step, i) => (
          <div class="flex gap-4">
            <div
              class="flex size-8 shrink-0 items-center justify-center rounded-full border font-mono text-sm font-medium"
              style={`border-color: color-mix(in srgb, ${accent} 35%, transparent); background: color-mix(in srgb, ${accent} 12%, transparent); color: color-mix(in srgb, ${accent} 65%, white);`}
            >
              {i + 1}
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold text-white">{step.title}</h3>
              <p class="mt-1.5 text-sm text-white/70 leading-relaxed">{step.description}</p>
              {step.image && (
                <div class="mt-4 overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03]">
                  <Image src={step.image} width={1000} format="webp" alt={step.caption ?? ""} class="w-full" />
                  <p class="border-t border-white/10 px-4 py-2.5 text-xs text-white/50">{step.caption}</p>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Open Questions</h2>
      <p class="max-w-[560px] text-white/80 leading-relaxed mb-4">
        The deck was built as a proposal, not a finished spec — several calls were left
        open on purpose, for the group to weigh in on before anything got locked down:
      </p>
      <ul class="max-w-[560px] space-y-2 text-sm text-white/70">
        {openQuestions.map((q) => (
          <li class="flex gap-2">
            <span class="mt-1.5 size-1.5 shrink-0 rounded-full" style={`background:${accent}`}></span>
            <span>{q}</span>
          </li>
        ))}
      </ul>
    </SectionContainer>

    <SectionContainer class="pb-24">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Visit the Site</h2>
      <p class="text-white/80 leading-relaxed max-w-[560px]">
        See the identity in context on the AVA group's homepage.
      </p>
      <a
        href="https://www.uco.es/investiga/grupos/ava/home/"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-mono text-white/80 transition hover:border-white/30 hover:bg-white/15 hover:text-white"
      >
        <Palette class="size-4" />
        uco.es/investiga/grupos/ava
      </a>
    </SectionContainer>

  </main>
</Layout>
