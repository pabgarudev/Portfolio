---
import Layout from "../../layouts/Layout.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import BackToProjects from "../../components/BackToProjects.astro";
import ProjectMetaPills from "../../components/ProjectMetaPills.astro";
import ProjectTags from "../../components/ProjectTags.astro";
import Book from "../../components/icons/Book.astro";
import Braces from "../../components/icons/Braces.astro";
import Palette from "../../components/icons/Palette.astro";
import Shield from "../../components/icons/Shield.astro";
import GitHubIcon from "../../components/icons/GitHub.astro";
import { accentFor } from "../../lib/categories";
import { creativeWorkSchema, breadcrumbSchema } from "../../lib/structuredData";

const title = "Portfolio";
const subtitle = "This Site — Personal Portfolio & Project Archive";
const year = 2025;
const category = "design";
const tags = ["Design", "Web Development"];

const accent = accentFor(category);

const stack = [
  { name: "Astro 5", description: "Content-focused static site framework — every project page here is a plain Astro component." },
  { name: "Tailwind CSS 4", description: "Utility-first styling, including the color-mix()-based accent system each project card runs on." },
  { name: "TypeScript", description: "Typed data and structured-data helpers, including this very projects list." },
  { name: "Vercel", description: "Hosting, plus @vercel/analytics for privacy-respecting page-view analytics." },
  { name: "@astrojs/sitemap", description: "Auto-generated sitemap for search engines." },
];

const details = [
  {
    title: "A computer-vision-themed intro",
    description: "The homepage opens with a small detection-style animation — a bounding box \"locking onto\" my photo, then an OCR-style caret sweeping across my name — a wink at the computer vision work the rest of the site is about.",
  },
  {
    title: "A bento-style project mosaic",
    description: "This page is a CSS grid with dense auto-flow, per-category accent colors, and live filters (Papers / Design / Others), sorted by year with pinned projects always floating to the top.",
  },
  {
    title: "SEO-conscious by default",
    description: "Every page ships JSON-LD structured data (Person, CreativeWork, Thesis, Breadcrumb schemas), canonical URLs, Open Graph and Twitter card metadata, and an auto-generated sitemap.",
  },
  {
    title: "Accessibility touches",
    description: "A skip-to-content link, semantic headings throughout, and every custom animation respects prefers-reduced-motion and turns itself off.",
  },
];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const structuredData = [
  creativeWorkSchema({
    headline: title,
    description: subtitle,
    author: "Pablo García-Ruiz",
    datePublished: String(year),
    url: pageUrl,
    image: new URL("/apple-touch-icon.png", Astro.site).toString(),
  }),
  breadcrumbSchema([
    { name: "Home", url: new URL("/", Astro.site).toString() },
    { name: "Projects", url: new URL("/projects", Astro.site).toString() },
    { name: title, url: pageUrl },
  ]),
];
---

<Layout title={`${title} - Pablo García Ruiz`} description={subtitle} structuredData={structuredData}>
  <main id="main-content" class="px-5 sm:px-8">
    <SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-16">
      <BackToProjects />

      <ProjectMetaPills year={year} category={category} />

      <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {title}
      </h1>
      <p class="mt-3 text-base lg:text-lg text-white/60 leading-relaxed">{subtitle}</p>

      <ProjectTags tags={tags} />
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Overview</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          My personal site and project archive — the page you're on right now.
          Designed and built from scratch rather than from a template, it's where my
          research, thesis, and design work all live side by side, including this
          project showcase describing itself.
        </p>
        <p>
          The goal was a site that reads as a single, coherent system: one dark
          theme, one accent-color language shared by every project category, and one
          card component reused everywhere from the homepage to the detail pages.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Palette class="size-5 text-white/40" />Design Details</h2>
      <div class="grid max-w-[680px] gap-3">
        {details.map((d) => (
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <span class="font-semibold text-white">{d.title}</span>
            <p class="mt-1 text-sm text-white/60 leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Braces class="size-5 text-white/40" />Tech Stack</h2>
      <div class="grid max-w-[680px] gap-3">
        {stack.map((s) => (
          <div class="flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <span class="font-mono text-sm font-semibold" style={`color: color-mix(in srgb, ${accent} 65%, white);`}>{s.name}</span>
            <span class="mt-1 text-sm text-white/60 leading-relaxed">{s.description}</span>
          </div>
        ))}
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Shield class="size-5 text-white/40" />Status</h2>
      <p class="max-w-[680px] text-white/80 leading-relaxed">
        Still actively evolving — new projects, sections, and small design
        refinements get added here as I build them, this entry included.
      </p>
    </SectionContainer>

    <SectionContainer class="pb-24">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><GitHubIcon class="size-5 text-white/40" />Source</h2>
      <p class="text-white/80 leading-relaxed max-w-[560px]">
        More of my work, including other side projects, is on GitHub.
      </p>
      <a
        href="https://github.com/pabgaru/"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-mono text-white/80 transition hover:border-white/30 hover:bg-white/15 hover:text-white"
      >
        <GitHubIcon class="size-4" />
        github.com/pabgaru
      </a>
    </SectionContainer>
  </main>
</Layout>
