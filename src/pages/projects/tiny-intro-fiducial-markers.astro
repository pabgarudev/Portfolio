---
import Layout from "../../layouts/Layout.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import BackToProjects from "../../components/BackToProjects.astro";
import ProjectMetaPills from "../../components/ProjectMetaPills.astro";
import ProjectTags from "../../components/ProjectTags.astro";
import TechStackPills from "../../components/TechStackPills.astro";
import GitHub from "../../components/icons/GitHub.astro";
import Book from "../../components/icons/Book.astro";
import Shield from "../../components/icons/Shield.astro";
import Download from "../../components/icons/Download.astro";
import Code from "../../components/icons/Code.astro";
import Article from "../../components/icons/Article.astro";
import DocumentMosaic from "../../components/DocumentMosaic.astro";
import { accentFor } from "../../lib/categories";
import { TECH } from "../../lib/techStack";
import { creativeWorkSchema, breadcrumbSchema } from "../../lib/structuredData";
import pageTitleImage from "../../assets/projects/tiny-intro-fiducial-markers/report/page-1-title.png";
import pageIntroImage from "../../assets/projects/tiny-intro-fiducial-markers/report/page-2-intro.png";
import pageExecutablesImage from "../../assets/projects/tiny-intro-fiducial-markers/report/page-3-executables.png";
import pageMarkersImage from "../../assets/projects/tiny-intro-fiducial-markers/report/page-4-markers.png";

const title = "Tiny Introduction to Fiducial Markers";
const subtitle = "A hands-on, from-scratch introduction to fiducial marker detection and pose estimation";
const year = 2023;
const category = "workshop";
const tags = ["Ready-to-use", "Open Source"];

const accent = accentFor(category);

const techStack = [TECH.cpp, TECH.opencv, TECH.cmake, TECH.ogre];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const structuredData = [
  creativeWorkSchema({
    headline: title,
    description: subtitle,
    author: "Pablo García-Ruiz",
    datePublished: String(year),
    url: pageUrl,
    image: new URL(pageTitleImage.src, Astro.site).toString(),
  }),
  breadcrumbSchema([
    { name: "Home", url: new URL("/", Astro.site).toString() },
    { name: "Projects", url: new URL("/projects", Astro.site).toString() },
    { name: title, url: pageUrl },
  ]),
];
---

<Layout title={`${title} - Pablo García Ruiz`} description={subtitle} image={pageTitleImage} structuredData={structuredData}>
  <main id="main-content" class="px-5 sm:px-8 overflow-x-hidden">
    <SectionContainer class="pt-28 sm:pt-36 lg:pt-44 pb-16">
      <BackToProjects />

      <ProjectMetaPills year={year} category={category} />

      <h1 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {title}
      </h1>
      <p class="mt-3 text-base lg:text-lg text-white/60 leading-relaxed">{subtitle}</p>

      <ProjectTags tags={tags} />

    </SectionContainer>

    <SectionContainer class="pb-20">
      <DocumentMosaic
        maxWidth="640px"
        cover={{
          src: pageTitleImage,
          alt: "Report cover page: Tiny introduction to fiducial markers",
        }}
        pages={[
          {
            src: pageIntroImage,
            alt: "Report page covering the introduction and prerequisites",
          },
          {
            src: pageMarkersImage,
            alt: "Report page with the printable Aruco marker set",
          },
          {
            src: pageExecutablesImage,
            alt: "Report page covering the workshop's executables",
          },
        ]}
      />
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Book class="size-5 text-white/40" />Overview</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          A self-contained workshop that introduces <strong class="text-white/85">fiducial
          markers</strong> from scratch, for anyone starting out in computer vision or
          augmented reality. It walks through Aruco marker detection, homography
          computation, pose estimation, and rendering a live 3D object that tracks a
          marker in real time.
        </p>
        <p>
          It's built as hands-on C++ exercises rather than slides alone: two
          progressively more complete applications, a printable marker set, and a full
          written report and slide deck to follow along with.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Code class="size-5 text-white/40" />What's Inside</h2>
      <ul class="max-w-[680px] space-y-3 text-sm text-white/70">
        <li class="flex gap-2">
          <span class="mt-1.5 size-1.5 shrink-0 rounded-full" style={`background:${accent}`}></span>
          <span><strong class="text-white/85">printMarkers</strong>: generates the printable Aruco marker set used throughout the workshop.</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-1.5 size-1.5 shrink-0 rounded-full" style={`background:${accent}`}></span>
          <span><strong class="text-white/85">mainApp</strong>: marker detection, pose estimation, and homography-based patch application.</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-1.5 size-1.5 shrink-0 rounded-full" style={`background:${accent}`}></span>
          <span><strong class="text-white/85">mainAppOvis</strong>: extends the pipeline with a live 3D object, rendered via OGRE/Ovis, that moves and rotates with the tracked marker.</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-1.5 size-1.5 shrink-0 rounded-full" style={`background:${accent}`}></span>
          <span><strong class="text-white/85">Report &amp; Slides</strong>: a full written report and presentation deck covering the theory behind each step.</span>
        </li>
      </ul>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Article class="size-5 text-white/40" />Report</h2>
      <div class="max-w-[680px] text-white/80 leading-relaxed space-y-4">
        <p>
          Alongside the two C++ applications, the workshop includes a{" "}
          <strong class="text-white/85">full written report</strong> that walks through
          the theory behind each exercise in the same order the code is built: how Aruco
          markers are detected and decoded, how a homography is computed from marker
          corners, how that homography leads to a full 6DoF pose estimate, and how the
          resulting pose drives a live 3D render.
        </p>
        <p>
          It's written to be read alongside <strong class="text-white/85">mainApp</strong>{" "}
          and <strong class="text-white/85">mainAppOvis</strong> rather than as a
          stand-alone document, every section maps to a concrete step in the code, and
          is paired with a slide deck covering the same material for anyone presenting or
          teaching from the workshop. The pages themselves are shown up top.
        </p>
      </div>
    </SectionContainer>

    <SectionContainer class="pb-16">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Download class="size-5 text-white/40" />Download</h2>
      <p class="text-white/80 leading-relaxed max-w-[560px]">
        The full workshop (code, printable markers, report, and slides) is available on GitHub.
      </p>
      <a
        href="https://github.com/pabgaruWorkshops/Tiny-Introduction-to-Fiducial-Markers"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-mono text-white/80 transition hover:border-white/30 hover:bg-white/15 hover:text-white"
      >
        <GitHub class="size-4" />
        View on GitHub
      </a>
      <TechStackPills stack={techStack} />
    </SectionContainer>

    <SectionContainer class="pb-24">
      <h2 class="flex items-center gap-2 text-xl font-bold text-white mb-4"><Shield class="size-5 text-white/40" />License</h2>
      <p class="text-white/80 text-sm max-w-[560px]">
        The repository's README notes an MIT License; a separate LICENSE file is not yet
        published in the repo.
      </p>
    </SectionContainer>

  </main>
</Layout>
